<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Expenses — TransPort Pro</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    /* ── Header Bar ── */
    .header-bar {
      background: #D85A30;
      color: white;
      padding: 0 20px;
      height: 52px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-radius: 10px 10px 0 0;
    }
    .header-bar .title { font-size: 16px; font-weight: 600; }

    /* ── Stat Cards ── */
    .stat-card {
      background: white;
      border-radius: 10px;
      border: 1px solid #dee2e6;
      padding: 14px 16px;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .stat-icon {
      width: 40px; height: 40px; border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px; flex-shrink: 0;
    }
    .stat-icon.blue   { background: #e8f0fe; }
    .stat-icon.green  { background: #e8f8ee; }
    .stat-icon.red    { background: #fdecea; }
    .stat-icon.orange { background: #fff0e8; }
    .stat-value { font-size: 22px; font-weight: 700; color: #1a1a1a; line-height: 1; }
    .stat-value.sm { font-size: 16px; }
    .stat-label { font-size: 12px; color: #6c757d; margin-top: 2px; }

    /* ── Table Card ── */
    .table-card {
      border: 1px solid #dee2e6;
      border-top: none;
      border-radius: 0 0 10px 10px;
      overflow: hidden;
      background: white;
    }

    /* ── Filter Bar ── */
    .filter-bar {
      padding: 14px 20px;
      background: #f8fafc;
      border-bottom: 1px solid #e2e8f0;
    }

    /* ── Table ── */
    .table-wrap { overflow-x: auto; }
    .pro-table { width: 100%; border-collapse: collapse; }
    .pro-table thead th {
      font-size: 11px; font-weight: 600;
      color: #6c757d; background: white;
      border-bottom: 1px solid #dee2e6;
      padding: 12px 16px;
      white-space: nowrap;
      text-transform: uppercase;
      letter-spacing: .4px;
    }
    .pro-table tbody td {
      padding: 13px 16px; font-size: 14px;
      vertical-align: middle;
      border-bottom: 1px solid #f1f1f1;
    }
    .pro-table tbody tr:last-child td { border-bottom: none; }
    .pro-table tbody tr:hover { background: #fafafa; }
    .pro-table tfoot td {
      padding: 12px 16px;
      font-size: 14px;
      font-weight: 700;
      background: #1a1a1a;
      color: white;
    }

    /* ── Category Badges ── */
    .badge-cat {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
    }
    .badge-fuel        { background: #fff0e8; color: #7a2f00; }
    .badge-maintenance { background: #e8f0fe; color: #1a3a6b; }
    .badge-salary      { background: #e8f8ee; color: #0a3622; }
    .badge-insurance   { background: #f5e8fe; color: #4a0080; }
    .badge-tax         { background: #fdecea; color: #842029; }
    .badge-other       { background: #f1f5f9; color: #475569; }

    /* ── Expense ID Badge ── */
    .exp-id {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 5px;
      background: #f1f5f9;
      font-size: 11px;
      font-weight: 600;
      color: #475569;
    }

    /* ── Buttons ── */
    .btn-add-expense {
      background: #1a1a1a; color: white; border: none;
      border-radius: 6px; padding: 0 14px; height: 34px;
      font-size: 13px; cursor: pointer;
      display: inline-flex; align-items: center; gap: 6px;
      text-decoration: none;
    }
    .btn-add-expense:hover { background: #333; color: white; }

    .btn-edit-xs {
      border: 1px solid #dee2e6;
      color: #475569; background: white;
      border-radius: 5px; padding: 3px 10px;
      font-size: 12px; text-decoration: none;
      font-weight: 500;
    }
    .btn-edit-xs:hover { background: #f8fafc; color: #475569; }

    .btn-del-xs {
      border: 1px solid #f8d7da;
      color: #842029; background: white;
      border-radius: 5px; padding: 3px 10px;
      font-size: 12px;
      font-weight: 500;
      cursor: pointer;
    }
    .btn-del-xs:hover { background: #fdecea; }

    .amount-cell {
      font-weight: 700;
      color: #D85A30;
      text-align: right;
    }

    .empty-state { text-align: center; padding: 48px 20px; color: #94a3b8; }
    .empty-icon  { font-size: 48px; margin-bottom: 10px; }

    .sub-text { font-size: 12px; color: #94a3b8; }
  </style>
</head>
<body>
<% locals.currentPath = '/expenses'; %>
<%- include('../partials/sidebar') %>
<div class="main-wrapper">
  <%- include('../partials/topbar') %>
  <div class="content-area">
    <%- include('../partials/flash') %>

    <!-- Stats -->
    <div class="row g-3 mb-4">
      <div class="col-6 col-md-3">
        <div class="stat-card">
          <div class="stat-icon blue">💸</div>
          <div>
            <div class="stat-value"><%= stats.total %></div>
            <div class="stat-label">Total Expenses</div>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-card">
          <div class="stat-icon orange">📅</div>
          <div>
            <div class="stat-value"><%= stats.thisMonth %></div>
            <div class="stat-label">This Month</div>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-card">
          <div class="stat-icon red">⛽</div>
          <div>
            <div class="stat-value sm">SAR <%= (stats.fuel[0]?.total || 0).toLocaleString() %></div>
            <div class="stat-label">Fuel Total</div>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-card">
          <div class="stat-icon green">🔧</div>
          <div>
            <div class="stat-value sm">SAR <%= (stats.maintenance[0]?.total || 0).toLocaleString() %></div>
            <div class="stat-label">Maintenance Total</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Header Bar -->
    <div class="header-bar mb-0">
      <span class="title">💸 Expense Management</span>
      <% if (currentRole === 'admin') { %>
        <a href="/expenses/add" class="btn-add-expense">⊕ Add Expense</a>
      <% } %>
    </div>

    <!-- Table Card -->
    <div class="table-card">

      <!-- Filter Bar -->
      <div class="filter-bar">
        <form method="GET" action="/expenses" class="row g-2 align-items-end">
          <div class="col-md-3">
            <input type="text" name="search" class="form-control form-control-sm"
              placeholder="Search description, paid to..." value="<%= filters.search %>">
          </div>
          <div class="col-md-2">
            <select name="category" class="form-select form-select-sm">
              <option value="">All Categories</option>
              <option value="fuel"        <%= filters.category === 'fuel'        ? 'selected' : '' %>>⛽ Fuel</option>
              <option value="maintenance" <%= filters.category === 'maintenance' ? 'selected' : '' %>>🔧 Maintenance</option>
              <option value="salary"      <%= filters.category === 'salary'      ? 'selected' : '' %>>💰 Salary</option>
              <option value="insurance"   <%= filters.category === 'insurance'   ? 'selected' : '' %>>🛡️ Insurance</option>
              <option value="tax"         <%= filters.category === 'tax'         ? 'selected' : '' %>>🏛️ Tax</option>
              <option value="other"       <%= filters.category === 'other'       ? 'selected' : '' %>>📦 Other</option>
            </select>
          </div>
          <div class="col-md-2">
            <input type="date" name="from" class="form-control form-control-sm" value="<%= filters.from %>">
          </div>
          <div class="col-md-2">
            <input type="date" name="to" class="form-control form-control-sm" value="<%= filters.to %>">
          </div>
          <div class="col-md-1">
            <button type="submit" class="btn btn-sm w-100" style="background:#D85A30;color:white;border:none;">🔍 Search</button>
          </div>
          <div class="col-md-1">
            <a href="/expenses" class="btn btn-outline-secondary btn-sm w-100">Reset</a>
          </div>
        </form>
      </div>

      <!-- Table -->
      <% if (expenses.length === 0) { %>
        <div class="empty-state">
          <div class="empty-icon">💸</div>
          <p>No expenses found</p>
        </div>
      <% } else { %>
      <div class="table-wrap">
        <table class="pro-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Date</th>
              <th>Category</th>
              <th>Description</th>
              <th>Car / Driver</th>
              <th>Paid To</th>
              <th>Method</th>
              <th style="text-align:right;">Amount</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% expenses.forEach(function(e) {
              const catMap = {
                fuel:        '⛽ Fuel',
                maintenance: '🔧 Maintenance',
                salary:      '💰 Salary',
                insurance:   '🛡️ Insurance',
                tax:         '🏛️ Tax',
                other:       '📦 Other'
              };
            %>
            <tr>
              <td><span class="exp-id"><%= e.expenseId %></span></td>
              <td style="font-size:13px;"><%= moment(e.expenseDate).format('DD MMM YYYY') %></td>
              <td>
                <span class="badge-cat badge-<%= e.category %>">
                  <%= catMap[e.category] || e.category %>
                </span>
              </td>
              <td style="font-size:13px;"><%= e.description || '—' %></td>
              <td>
                <% if (e.car) { %>
                  <div class="sub-text">🚘 <%= e.car.name %> · <%= e.car.numberPlate %></div>
                <% } %>
                <% if (e.driver) { %>
                  <div class="sub-text">👤 <%= e.driver.name %></div>
                <% } %>
                <% if (!e.car && !e.driver) { %>—<% } %>
              </td>
              <td style="font-size:13px;"><%= e.paidTo || '—' %></td>
              <td style="font-size:12px;color:#6c757d;"><%= e.paymentMethod %></td>
              <td class="amount-cell">SAR <%= e.amount.toLocaleString() %></td>
              <td>
                <div class="d-flex gap-1">
                  <% if (currentRole === 'admin') { %>
                    <a href="/expenses/<%= e._id %>/edit" class="btn-edit-xs">Edit</a>
                    <form action="/expenses/<%= e._id %>?_method=DELETE" method="POST" class="d-inline"
                      onsubmit="return confirm('Delete this expense?')">
                      <button type="submit" class="btn-del-xs">🗑️</button>
                    </form>
                  <% } %>
                </div>
              </td>
            </tr>
            <% }); %>
          </tbody>
          <tfoot>
            <tr>
              <td colspan="7" class="fw-bold">Total</td>
              <td style="text-align:right;font-weight:700;">SAR <%= stats.totalAmount.toLocaleString() %></td>
              <td></td>
            </tr>
          </tfoot>
        </table>
      </div>
      <% } %>

    </div><!-- /table-card -->

  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
