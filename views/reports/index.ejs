<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Reports — TransPort Pro</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    /* ── Header Bar ── */
    .header-bar {
      background: #D85A30;
      color: white;
      padding: 0 20px;
      height: 52px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-radius: 10px 10px 0 0;
    }
    .header-bar .title { font-size: 16px; font-weight: 600; }
    .header-bar .subtitle { font-size: 13px; opacity: .85; }

    /* ── Stat Cards ── */
    .stat-card {
      background: white;
      border-radius: 10px;
      border: 1px solid #dee2e6;
      padding: 14px 16px;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .stat-icon {
      width: 40px; height: 40px; border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px; flex-shrink: 0;
    }
    .stat-icon.blue   { background: #e8f0fe; }
    .stat-icon.gold   { background: #fff8e1; }
    .stat-icon.green  { background: #e8f8ee; }
    .stat-icon.red    { background: #fdecea; }
    .stat-icon.purple { background: #f5f0ff; }
    .stat-icon.orange { background: #fff0e8; }
    .stat-value { font-size: 18px; font-weight: 700; color: #1a1a1a; line-height: 1; }
    .stat-label { font-size: 12px; color: #6c757d; margin-top: 2px; }

    /* ── Table Card ── */
    .table-card {
      border: 1px solid #dee2e6;
      border-top: none;
      border-radius: 0 0 10px 10px;
      overflow: hidden;
      background: white;
    }

    /* ── Filter Bar ── */
    .filter-bar {
      padding: 14px 20px;
      background: #f8fafc;
      border-bottom: 1px solid #e2e8f0;
    }

    /* ── Section Cards (charts, tables) ── */
    .section-wrap {
      border: 1px solid #dee2e6;
      border-radius: 10px;
      overflow: hidden;
      background: white;
      margin-bottom: 0;
    }
    .section-header {
      background: #D85A30;
      color: white;
      padding: 12px 18px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .section-header .sh-title { font-size: 14px; font-weight: 600; }
    .section-header .sh-sub   { font-size: 12px; opacity: .85; }
    .section-body { padding: 18px 20px; }

    /* ── Profit Cards ── */
    .profit-card {
      background: white;
      border: 1px solid #dee2e6;
      border-radius: 10px;
      padding: 16px;
      position: relative;
      overflow: hidden;
    }
    .profit-card .pc-label {
      font-size: 11px; font-weight: 600;
      text-transform: uppercase; letter-spacing: .6px;
      color: #6c757d; margin-bottom: 6px;
    }
    .profit-card .pc-value { font-size: 20px; font-weight: 700; line-height: 1; }
    .profit-card .pc-sub   { font-size: 12px; color: #94a3b8; margin-top: 4px; }
    .profit-card .pc-icon  {
      position: absolute; bottom: 8px; right: 10px;
      font-size: 32px; opacity: .08;
    }
    .profit-card.net-pos { border-left: 4px solid #1e7e34; }
    .profit-card.net-neg { border-left: 4px solid #c0392b; }
    .profit-pos { color: #1e7e34; font-weight: 700; }
    .profit-neg { color: #c0392b; font-weight: 700; }

    /* ── Table ── */
    .table-wrap { overflow-x: auto; }
    .pro-table { width: 100%; border-collapse: collapse; }
    .pro-table thead th {
      font-size: 11px; font-weight: 600;
      color: #6c757d; background: #f8fafc;
      border-bottom: 1px solid #e2e8f0;
      padding: 10px 16px;
      white-space: nowrap;
      text-transform: uppercase;
      letter-spacing: .4px;
    }
    .pro-table tbody td {
      padding: 12px 16px; font-size: 13.5px;
      vertical-align: middle;
      border-bottom: 1px solid #f1f1f1;
    }
    .pro-table tbody tr:last-child td { border-bottom: none; }
    .pro-table tbody tr:hover { background: #fafafa; }
    .pro-table tfoot td {
      padding: 12px 16px; font-size: 13.5px;
      font-weight: 700; background: #f8fafc;
      border-top: 2px solid #dee2e6;
    }

    /* ── Badges ── */
    .badge-status {
      display: inline-block; padding: 3px 10px;
      border-radius: 20px; font-size: 11px;
      font-weight: 600; text-transform: capitalize;
    }
    .badge-pending   { background: #fff3cd; color: #856404; }
    .badge-confirmed { background: #cfe2ff; color: #084298; }
    .badge-ongoing   { background: #d1e7dd; color: #0a3622; }
    .badge-completed { background: #d2f4ea; color: #0a3622; }
    .badge-cancelled { background: #f8d7da; color: #842029; }

    /* ── Expense breakdown grid ── */
    .expense-grid { display: flex; flex-wrap: wrap; }
    .expense-cell {
      flex: 1 1 25%;
      min-width: 140px;
      padding: 14px 18px;
      text-align: center;
      border-right: 1px solid #f1f1f1;
      border-bottom: 1px solid #f1f1f1;
    }
    .expense-cell:last-child { border-right: none; }
    .expense-cell .ec-label { font-size: 11px; color: #6c757d; font-weight: 600; text-transform: uppercase; letter-spacing: .5px; margin-bottom: 4px; }
    .expense-cell .ec-value { font-size: 15px; font-weight: 700; color: #c0392b; }

    /* ── Booking ID link ── */
    .booking-id-link { color: #D85A30; font-weight: 700; text-decoration: none; }
    .booking-id-link:hover { text-decoration: underline; }

    .empty-state { text-align: center; padding: 36px 20px; color: #94a3b8; }
  </style>
</head>
<body>
<% locals.currentPath = '/reports'; %>
<%- include('../partials/sidebar') %>
<div class="main-wrapper">
  <%- include('../partials/topbar') %>
  <div class="content-area">
    <%- include('../partials/flash') %>

    <!-- ── Date Filter ── -->
    <div class="header-bar mb-0">
      <span class="title">📅 Filter Period</span>
    </div>
    <div class="table-card mb-4">
      <div class="filter-bar">
        <form method="GET" class="row g-2 align-items-end">
          <div class="col-md-3">
            <label class="form-label" style="font-size:11px;color:#64748b;">From Date</label>
            <input type="date" name="from" class="form-control form-control-sm" value="<%= filters.from %>">
          </div>
          <div class="col-md-3">
            <label class="form-label" style="font-size:11px;color:#64748b;">To Date</label>
            <input type="date" name="to" class="form-control form-control-sm" value="<%= filters.to %>">
          </div>
          <div class="col-md-2">
            <button class="btn btn-sm w-100" style="background:#D85A30;color:white;border:none;">🔍 Apply</button>
          </div>
          <div class="col-md-2">
            <a href="/reports" class="btn btn-outline-secondary btn-sm w-100">This Month</a>
          </div>
        </form>
      </div>
    </div>

    <!-- ── Row 1: Booking Summary ── -->
    <div class="row g-3 mb-3">
      <div class="col-6 col-md-3">
        <div class="stat-card"><div class="stat-icon blue">📋</div><div><div class="stat-value"><%= totalBookings %></div><div class="stat-label">Total Bookings</div></div></div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-card"><div class="stat-icon gold">💰</div><div><div class="stat-value">SAR <%= totalRevenue.toLocaleString() %></div><div class="stat-label">Total Revenue</div></div></div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-card"><div class="stat-icon green">✅</div><div><div class="stat-value">SAR <%= totalCollected.toLocaleString() %></div><div class="stat-label">Collected</div></div></div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-card"><div class="stat-icon red">⏳</div><div><div class="stat-value">SAR <%= totalPending.toLocaleString() %></div><div class="stat-label">Outstanding</div></div></div>
      </div>
    </div>

    <!-- ── Row 2: Profit Summary ── -->
    <div class="row g-3 mb-4">
      <div class="col-6 col-md-3">
        <div class="profit-card">
          <div class="pc-label">📦 Booking Cost</div>
          <div class="pc-value text-danger">SAR <%= totalCost.toLocaleString() %></div>
          <div class="pc-sub">Booking ki lagat</div>
          <div class="pc-icon">📦</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="profit-card">
          <div class="pc-label">📊 Gross Profit</div>
          <div class="pc-value <%= grossProfit >= 0 ? 'profit-pos' : 'profit-neg' %>">SAR <%= grossProfit.toLocaleString() %></div>
          <div class="pc-sub">Revenue − Cost</div>
          <div class="pc-icon">📊</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="profit-card">
          <div class="pc-label">💸 Total Expenses</div>
          <div class="pc-value text-danger">SAR <%= totalExpenses.toLocaleString() %></div>
          <div class="pc-sub">Petrol, food, services</div>
          <div class="pc-icon">💸</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="profit-card <%= netProfit >= 0 ? 'net-pos' : 'net-neg' %>">
          <div class="pc-label">✅ Net Profit</div>
          <div class="pc-value <%= netProfit >= 0 ? 'profit-pos' : 'profit-neg' %>">SAR <%= netProfit.toLocaleString() %></div>
          <div class="pc-sub">Gross − Expenses</div>
          <% if (netProfit < 0) { %>
            <span class="badge bg-danger mt-2 d-inline-block" style="font-size:10px;">⚠️ Nuqsan</span>
          <% } else { %>
            <span class="badge bg-success mt-2 d-inline-block" style="font-size:10px;">✅ Faida</span>
          <% } %>
          <div class="pc-icon">📈</div>
        </div>
      </div>
    </div>

    <!-- ── Charts Row ── -->
    <div class="row g-3 mb-4">
      <div class="col-12 col-lg-8">
        <div class="section-wrap">
          <div class="section-header">
            <span class="sh-title">📈 Daily Revenue, Expenses & Net Profit</span>
          </div>
          <div class="section-body">
            <div style="position:relative;height:300px;width:100%;">
              <canvas id="revenueChart"></canvas>
            </div>
          </div>
        </div>
      </div>
      <div class="col-12 col-lg-4">
        <div class="section-wrap">
          <div class="section-header">
            <span class="sh-title">🥧 Booking Status</span>
          </div>
          <div class="section-body">
            <canvas id="statusChart"></canvas>
            <div class="mt-3" style="font-size:13px;">
              <div class="d-flex justify-content-between mb-1"><span>✅ Completed</span><strong><%= completed %></strong></div>
              <div class="d-flex justify-content-between mb-1"><span>❌ Cancelled</span><strong><%= cancelled %></strong></div>
              <div class="d-flex justify-content-between"><span>🔄 Others</span><strong><%= totalBookings - completed - cancelled %></strong></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ── Expense Category Breakdown ── -->
    <div class="section-wrap mb-4">
      <div class="section-header">
        <span class="sh-title">💸 Expenses — Category Breakdown</span>
        <span class="sh-sub">Is period mein</span>
      </div>
      <% if (expenseCategoryTotals && expenseCategoryTotals.length > 0) { %>
      <div class="expense-grid">
        <% expenseCategoryTotals.forEach(function(ec) { %>
        <div class="expense-cell">
          <div class="ec-label"><%= ec._id || 'Other' %></div>
          <div class="ec-value">SAR <%= ec.total.toLocaleString() %></div>
        </div>
        <% }); %>
      </div>
      <% } else { %>
        <div class="empty-state">Is period mein koi expense record nahi</div>
      <% } %>
    </div>

    <!-- ── Daily Breakdown Table ── -->
    <div class="section-wrap mb-4">
      <div class="section-header">
        <span class="sh-title">📅 Daily Breakdown</span>
        <span class="sh-sub"><%= dailyData.length %> din</span>
      </div>
      <div class="table-wrap">
        <table class="pro-table">
          <thead>
            <tr>
              <th>Date</th>
              <th>Revenue</th>
              <th>Booking Cost</th>
              <th>Gross Profit</th>
              <th>Expenses</th>
              <th>Net Profit</th>
            </tr>
          </thead>
          <tbody>
            <% if (dailyData.length === 0) { %>
              <tr><td colspan="6" class="text-center py-4 text-muted">Is period mein koi data nahi</td></tr>
            <% } %>
            <% dailyData.forEach(function(d) { %>
            <tr>
              <td class="fw-semibold"><%= d._id %></td>
              <td>SAR <%= (d.revenue || 0).toLocaleString() %></td>
              <td class="text-muted">SAR <%= (d.cost || 0).toLocaleString() %></td>
              <td class="<%= (d.gross || 0) >= 0 ? 'profit-pos' : 'profit-neg' %>">SAR <%= (d.gross || 0).toLocaleString() %></td>
              <td class="text-danger">
                <% if ((d.expenses || 0) > 0) { %>− SAR <%= d.expenses.toLocaleString() %><% } else { %><span class="text-muted">—</span><% } %>
              </td>
              <td class="<%= (d.net || 0) >= 0 ? 'profit-pos' : 'profit-neg' %>">SAR <%= (d.net || 0).toLocaleString() %></td>
            </tr>
            <% }); %>
          </tbody>
          <tfoot>
            <tr>
              <td>Total</td>
              <td>SAR <%= totalRevenue.toLocaleString() %></td>
              <td class="text-muted">SAR <%= totalCost.toLocaleString() %></td>
              <td class="<%= grossProfit >= 0 ? 'profit-pos' : 'profit-neg' %>">SAR <%= grossProfit.toLocaleString() %></td>
              <td class="text-danger">− SAR <%= totalExpenses.toLocaleString() %></td>
              <td class="<%= netProfit >= 0 ? 'profit-pos' : 'profit-neg' %>">SAR <%= netProfit.toLocaleString() %></td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>

    <!-- ── Top Cars + Drivers ── -->
    <div class="row g-3 mb-4">
      <div class="col-12 col-lg-6">
        <div class="section-wrap">
          <div class="section-header"><span class="sh-title">🏆 Top Performing Cars</span></div>
          <div class="table-wrap">
            <table class="pro-table">
              <thead><tr><th>Car</th><th>Trips</th><th>Revenue</th></tr></thead>
              <tbody>
                <% if (topCars.length === 0) { %>
                  <tr><td colspan="3" class="text-center py-4 text-muted">No data</td></tr>
                <% } %>
                <% topCars.forEach(function(c, i) { %>
                <tr>
                  <td>
                    <span class="me-2" style="font-weight:700;"><%- ['🥇','🥈','🥉','4️⃣','5️⃣'][i] %></span>
                    <%= c.car.name %> <%= c.car.model %>
                  </td>
                  <td><span class="badge bg-info text-dark"><%= c.trips %></span></td>
                  <td style="font-weight:600;">SAR <%= c.revenue?.toLocaleString() %></td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      <div class="col-12 col-lg-6">
        <div class="section-wrap">
          <div class="section-header"><span class="sh-title">🏆 Top Drivers</span></div>
          <div class="table-wrap">
            <table class="pro-table">
              <thead><tr><th>Driver</th><th>Trips</th><th>Revenue Generated</th></tr></thead>
              <tbody>
                <% if (topDrivers.length === 0) { %>
                  <tr><td colspan="3" class="text-center py-4 text-muted">No data</td></tr>
                <% } %>
                <% topDrivers.forEach(function(d, i) { %>
                <tr>
                  <td>
                    <span class="me-2" style="font-weight:700;"><%- ['🥇','🥈','🥉','4️⃣','5️⃣'][i] %></span>
                    <%= d.driver.name %>
                  </td>
                  <td><span class="badge bg-success"><%= d.trips %></span></td>
                  <td style="font-weight:600;">SAR <%= d.revenue?.toLocaleString() %></td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- ── All Bookings Table ── -->
    <div class="section-wrap mb-4">
      <div class="section-header">
        <span class="sh-title">📋 All Bookings — Selected Period</span>
        <span class="sh-sub"><%= bookings.length %> bookings</span>
      </div>
      <div class="table-wrap">
        <table class="pro-table">
          <thead>
            <tr>
              <th>ID</th><th>Customer</th><th>Car</th><th>Type</th>
              <th>Dates</th><th>Total</th><th>Paid</th><th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% if (bookings.length === 0) { %>
              <tr><td colspan="8" class="text-center py-4 text-muted">No bookings</td></tr>
            <% } %>
            <% bookings.forEach(function(b) { %>
            <tr>
              <td><a href="/bookings/<%= b._id %>" class="booking-id-link"><%= b.bookingId %></a></td>
              <td><%= b.customerName %></td>
              <td><%= b.car ? b.car.name : '—' %></td>
              <td>
                <span class="badge bg-<%= b.bookingType === 'daily' ? 'info' : 'warning' %> text-dark" style="font-size:11px;">
                  <%= b.bookingType %>
                </span>
              </td>
              <td style="font-size:12px;">
                <%= moment(b.startDate).format('DD MMM') %> → <%= moment(b.endDate).format('DD MMM YY') %>
              </td>
              <td style="font-weight:600;">SAR <%= b.totalAmount?.toLocaleString() %></td>
              <td>SAR <%= b.advancePaid?.toLocaleString() %></td>
              <td><span class="badge-status badge-<%= b.status %>"><%= b.status %></span></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
const dailyData = <%- JSON.stringify(dailyData || []) %>;
const completedCount = <%= completed || 0 %>;
const cancelledCount = <%= cancelled || 0 %>;
const totalBookingCount = <%= totalBookings || 0 %>;
const otherCount = Math.max(totalBookingCount - completedCount - cancelledCount, 0);

const revenueCanvas = document.getElementById('revenueChart');
if (revenueCanvas) {
  new Chart(revenueCanvas.getContext('2d'), {
    type: 'bar',
    data: {
      labels: dailyData.map(d => d._id || ''),
      datasets: [
        {
          label: 'Revenue',
          data: dailyData.map(d => d.revenue || 0),
          backgroundColor: 'rgba(216,90,48,0.75)',
          borderColor: '#D85A30',
          borderWidth: 1,
          borderRadius: 4,
          order: 2
        },
        {
          label: 'Expenses',
          data: dailyData.map(d => d.expenses || 0),
          backgroundColor: 'rgba(239,68,68,0.55)',
          borderColor: '#c0392b',
          borderWidth: 1,
          borderRadius: 4,
          order: 3
        },
        {
          label: 'Net Profit',
          data: dailyData.map(d => d.net || 0),
          type: 'line',
          borderColor: '#10b981',
          backgroundColor: 'rgba(16,185,129,0.08)',
          borderWidth: 3,
          pointRadius: 4,
          pointHoverRadius: 6,
          pointBackgroundColor: '#10b981',
          tension: 0.35,
          fill: true,
          order: 1
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      animation: false,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: { display: true, position: 'top' },
        tooltip: {
          callbacks: {
            label: ctx => ctx.dataset.label + ': SAR ' + (ctx.raw || 0).toLocaleString()
          }
        }
      },
      scales: {
        y: {
          beginAtZero: true,
          ticks: { callback: value => 'SAR ' + value.toLocaleString() }
        }
      }
    }
  });
}

const statusCanvas = document.getElementById('statusChart');
if (statusCanvas) {
  new Chart(statusCanvas.getContext('2d'), {
    type: 'doughnut',
    data: {
      labels: ['Completed', 'Cancelled', 'Others'],
      datasets: [{
        data: [completedCount, cancelledCount, otherCount],
        backgroundColor: ['#10b981', '#ef4444', '#D85A30'],
        hoverOffset: 6,
        borderWidth: 0
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      cutout: '70%',
      plugins: {
        legend: {
          position: 'bottom',
          labels: { padding: 15, usePointStyle: true }
        },
        tooltip: {
          callbacks: { label: ctx => ctx.label + ': ' + ctx.raw }
        }
      }
    }
  });
}
</script>
</body>
</html>
