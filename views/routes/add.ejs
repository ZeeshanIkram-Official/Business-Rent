<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Add Route — TransPort Pro</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<% locals.currentPath = '/routes'; %>
<%- include('../partials/sidebar') %>
<div class="main-wrapper">
  <%- include('../partials/topbar') %>
  <div class="content-area">
    <%- include('../partials/flash') %>

    <div class="d-flex align-items-center gap-3 mb-4">
      <a href="/routes" class="btn btn-outline-secondary btn-sm">← Back</a>
      <h5 class="mb-0 fw-bold">➕ Add New Route</h5>
    </div>

    <div class="row justify-content-center">
      <div class="col-12 col-lg-8">
        <form action="/routes" method="POST">

          <!-- Company Details -->
          <div class="form-section">
            <div class="form-section-header">🏢 Company Details</div>
            <div class="form-section-body">
              <div class="row g-3">
                <div class="col-12">
                  <label class="form-label">Company Name *</label>
                  <input type="text" name="company" class="form-control" required
                    placeholder="e.g. Tech Solutions Ltd" oninput="checkDuplicate()">
                </div>
              </div>
            </div>
          </div>

          <!-- Route Details -->
          <div class="form-section">
            <div class="form-section-header">🗺️ Route Details</div>
            <div class="form-section-body">
              <div class="row g-3">
                <div class="col-md-6">
                  <label class="form-label">Origin (From) *</label>
                  <input type="text" name="origin" class="form-control" required
                    placeholder="e.g. Makkah" id="origin" oninput="updatePreview()">
                </div>
                <div class="col-md-6">
                  <label class="form-label">Destination (To) *</label>
                  <input type="text" name="destination" class="form-control" required
                    placeholder="e.g. Madina" id="destination" oninput="updatePreview()">
                </div>
                <div class="col-12">
                  <div class="p-2 rounded text-center fw-semibold"
                    style="background:#eff6ff;color:#1d4ed8;font-size:15px;" id="routePreview">
                    — → —
                  </div>
                  <!-- Duplicate Warning -->
                  <div id="duplicateWarning" class="alert alert-danger mt-2 d-none py-2">
                    ⚠️ Yeh route is company ke liye pehle se exist karta hai!
                  </div>
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-semibold">Default Price (SAR) *</label>
                  <input type="number" name="price" class="form-control form-control-lg"
                    placeholder="0" min="0" value="0" required>
                  <small class="text-muted">Booking ke waqt change bhi ho sakta hai</small>
                </div>
                <div class="col-12">
                  <label class="form-label">Notes</label>
                  <textarea name="notes" class="form-control" rows="2"
                    placeholder="Any additional info…"></textarea>
                </div>
              </div>
            </div>
          </div>

          <!-- Status -->
          <div class="form-section">
            <div class="form-section-header">🔘 Status</div>
            <div class="form-section-body">
              <label class="form-label">Route Status *</label>
              <select name="isActive" class="form-select" id="statusSelect"
                onchange="updateBadge()" style="max-width:260px;">
                <option value="true">✅ Active</option>
                <option value="false">🚫 Inactive</option>
              </select>
              <div class="mt-2 d-flex align-items-center gap-2">
                <span id="statusBadge" class="badge bg-success">Active</span>
                <small id="statusHint" class="text-muted">Route booking ke liye available hogi</small>
              </div>
            </div>
          </div>

          <div class="d-flex gap-2 justify-content-end mt-3">
            <a href="/routes" class="btn btn-outline-secondary">Cancel</a>
            <button type="submit" class="btn btn-primary" id="saveBtn">✅ Save Route</button>
          </div>

        </form>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
function updatePreview() {
  const o = document.getElementById('origin').value.trim() || '—';
  const d = document.getElementById('destination').value.trim() || '—';
  document.getElementById('routePreview').textContent = o + ' → ' + d;
  checkDuplicate();
}

async function checkDuplicate() {
  const company     = document.querySelector('[name="company"]').value.trim();
  const origin      = document.getElementById('origin').value.trim();
  const destination = document.getElementById('destination').value.trim();
  const warning     = document.getElementById('duplicateWarning');
  const saveBtn     = document.getElementById('saveBtn');

  if (!company || !origin || !destination) {
    warning.classList.add('d-none');
    saveBtn.disabled = false;
    return;
  }

  const res  = await fetch(`/routes/check-duplicate?company=${encodeURIComponent(company)}&origin=${encodeURIComponent(origin)}&destination=${encodeURIComponent(destination)}`);
  const data = await res.json();

  if (data.exists) {
    warning.classList.remove('d-none');
    saveBtn.disabled = true;
  } else {
    warning.classList.add('d-none');
    saveBtn.disabled = false;
  }
}

function updateBadge() {
  const val   = document.getElementById('statusSelect').value;
  const badge = document.getElementById('statusBadge');
  const hint  = document.getElementById('statusHint');
  if (val === 'true') {
    badge.className   = 'badge bg-success';
    badge.textContent = 'Active';
    hint.textContent  = 'Route booking ke liye available hogi';
  } else {
    badge.className   = 'badge bg-danger';
    badge.textContent = 'Inactive';
    hint.textContent  = 'Route hidden rahegi, booking nahi hogi';
  }
}
</script>
</body>
</html>