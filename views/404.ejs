<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>404 — TransPort Pro</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { background: linear-gradient(135deg,#0f2544,#1a3c5e); min-height:100vh; display:flex; align-items:center; justify-content:center; color:#fff; text-align:center; }
  </style>
</head>
<body>
  <div>
    <div style="font-size:80px;">🚘</div>
    <h1 style="font-size:72px;font-weight:800;margin:0;">404</h1>
    <p style="font-size:20px;opacity:.8;">Page not found</p>
    <p style="opacity:.6;font-size:14px;"><%= locals.url || '' %></p>
    <a href="/dashboard" class="btn" style="background:#f59e0b;color:#fff;border:none;padding:12px 32px;border-radius:8px;font-weight:700;">Go to Dashboard</a>
  </div>
