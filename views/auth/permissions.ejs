<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Role Permissions</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <style>
    body { background: #f5f7fb; font-size: 14px; }
    .main { margin-left: 220px; }
    @media(max-width:768px) { .main { margin-left: 60px; } }

    .role-tab {
      cursor: pointer;
      border: 2px solid #dee2e6;
      border-radius: 8px;
      padding: 10px 16px;
      background: #fff;
      transition: all 0.15s;
      text-decoration: none;
      color: #333;
      display: flex;
      align-items: center;
      gap: 8px;
      font-weight: 500;
    }
    .role-tab:hover { border-color: #1a6fbc; color: #1a6fbc; background: #f0f7ff; }
    .role-tab.active { border-color: #1a6fbc; background: #1a6fbc; color: #fff; }
    .role-tab .badge-role {
      font-size: 10px;
      padding: 2px 7px;
      border-radius: 20px;
      background: rgba(255,255,255,0.25);
    }
    .role-tab.active .badge-role { background: rgba(255,255,255,0.3); }

    .screen-card {
      border: 2px solid #dee2e6;
      border-radius: 10px;
      padding: 14px 16px;
      background: #fff;
      cursor: pointer;
      transition: all 0.15s;
      user-select: none;
    }
    .screen-card:hover { border-color: #1a6fbc; background: #f0f7ff; }
    .screen-card.checked { border-color: #198754; background: #f0fff5; }

    .screen-card input[type="checkbox"] { display: none; }

    .screen-icon { font-size: 1.4rem; }
    .screen-label { font-weight: 600; font-size: 13px; color: #333; }
    .check-indicator {
      width: 22px; height: 22px;
      border-radius: 50%;
      border: 2px solid #ccc;
      display: flex; align-items: center; justify-content: center;
      font-size: 11px;
      color: transparent;
      background: #fff;
      transition: all 0.15s;
      flex-shrink: 0;
    }
    .screen-card.checked .check-indicator {
      background: #198754;
      border-color: #198754;
      color: #fff;
    }

    .select-all-btn {
      font-size: 12px;
      cursor: pointer;
      color: #1a6fbc;
      text-decoration: underline;
      border: none;
      background: none;
      padding: 0;
    }
    .admin-lock-notice {
      background: #fff3cd;
      border-left: 4px solid #ffc107;
      border-radius: 6px;
      padding: 10px 14px;
      font-size: 13px;
    }
  </style>
</head>
<body>

<%- include('../partials/sidebar', { currentPage: 'permissions' }) %>

<main class="main p-4">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="h5 fw-bold mb-0">🔐 Role Permissions</h2>
      <p class="text-muted small mb-0 mt-1">Har role ko sirf wo screens dikhayein jo aap allow karein</p>
    </div>
  </div>

  <% if (success && success.length > 0) { %>
    <div class="alert alert-success border-start border-success border-4">✅ <%= success %></div>
  <% } %>
  <% if (error && error.length > 0) { %>
    <div class="alert alert-danger border-start border-danger border-4">❌ <%= error %></div>
  <% } %>

  <div class="row g-4">

    <%# Left — Role Tabs %>
    <div class="col-12 col-md-3">
      <div class="card shadow-sm">
        <div class="card-header bg-light py-3">
          <h6 class="mb-0 fw-semibold">Roles</h6>
        </div>
        <div class="card-body p-3">
          <div class="d-flex flex-column gap-2">
            <% roles.forEach(role => { %>
              <a href="/permissions?role=<%= encodeURIComponent(role) %>"
                 class="role-tab <%= selectedRole === role ? 'active' : '' %>">
                <span><%= role === 'admin' ? '👑' : role === 'booking_agent' ? '🧑‍💼' : '👤' %></span>
                <span class="text-capitalize"><%= role %></span>
              </a>
            <% }) %>
          </div>

          <% if (selectedRole === 'admin') { %>
            <div class="admin-lock-notice mt-3">
              ⚠️ Admin ko hamesha sari screens dikhti hain — restrictions apply nahi hoti.
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <%# Right — Screens Checklist %>
    <div class="col-12 col-md-9">
      <div class="card shadow-sm">
        <div class="card-header bg-light py-3 d-flex align-items-center justify-content-between">
          <h6 class="mb-0 fw-semibold">
            <span class="text-capitalize"><%= selectedRole %></span> role — Screen Permissions
          </h6>
          <% if (selectedRole !== 'admin') { %>
            <div class="d-flex gap-3">
              <button type="button" class="select-all-btn" onclick="selectAll(true)">Sab Select</button>
              <span class="text-muted">|</span>
              <button type="button" class="select-all-btn" style="color:#dc3545;" onclick="selectAll(false)">Sab Hatao</button>
            </div>
          <% } %>
        </div>
        <div class="card-body p-4">

          <% if (selectedRole === 'admin') { %>
            <div class="text-center py-4 text-muted">
              <div style="font-size:2.5rem">👑</div>
              <p class="mt-2">Admin role ko by default sari screens accessible hain.<br>Koi restriction set nahi ki ja sakti.</p>
            </div>
          <% } else { %>

            <form action="/permissions/save" method="POST" id="permForm">
              <input type="hidden" name="role" value="<%= selectedRole %>">

              <div class="row g-3 mb-4">
                <% allScreens.forEach(screen => { %>
                  <% const isChecked = currentPerms.includes(screen.key); %>
                  <div class="col-6 col-md-4">
                    <label class="screen-card w-100 d-flex align-items-center gap-3 <%= isChecked ? 'checked' : '' %>"
                           onclick="toggleCard(this)">
                      <input type="checkbox" name="screens" value="<%= screen.key %>"
                             <%= isChecked ? 'checked' : '' %>>
                      <span class="screen-icon"><%= screen.icon %></span>
                      <span class="screen-label flex-fill"><%= screen.label %></span>
                      <span class="check-indicator"><i class="fa fa-check"></i></span>
                    </label>
                  </div>
                <% }) %>
              </div>

              <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">
                  💾 Save Permissions
                </button>
                <a href="/permissions?role=<%= selectedRole %>" class="btn btn-outline-secondary">
                  Reset
                </a>
              </div>
            </form>

          <% } %>
        </div>
      </div>
    </div>

  </div>
</main>

<script>
  function toggleCard(label) {
    const cb = label.querySelector('input[type="checkbox"]');
    cb.checked = !cb.checked;
    label.classList.toggle('checked', cb.checked);
  }

  function selectAll(val) {
    document.querySelectorAll('.screen-card').forEach(card => {
      const cb = card.querySelector('input[type="checkbox"]');
      cb.checked = val;
      card.classList.toggle('checked', val);
    });
  }
</script>

</body>
</html>
