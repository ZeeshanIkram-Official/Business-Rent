<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit User — TransPort Pro</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <style>
    body { background: #f5f7fb; font-size: 14px; }

    /* ── Header Bar ── */
    .header-bar {
      background: #D85A30;
      color: white;
      padding: 0 20px;
      height: 52px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-radius: 10px 10px 0 0;
    }
    .header-bar .title { font-size: 16px; font-weight: 600; }

    /* ── Form Card ── */
    .form-card {
      border: 1px solid #dee2e6;
      border-top: none;
      border-radius: 0 0 10px 10px;
      background: white;
      padding: 28px;
    }

    /* ── Labels ── */
    .form-label-custom {
      font-size: 12px;
      font-weight: 600;
      color: #6c757d;
      text-transform: uppercase;
      letter-spacing: .4px;
      margin-bottom: 5px;
    }

    /* ── Inputs ── */
    .form-control:focus, .form-select:focus {
      border-color: #D85A30;
      box-shadow: 0 0 0 0.2rem rgba(216,90,48,.15);
    }
    input[readonly] {
      background-color: #f8fafc;
      cursor: not-allowed;
      color: #94a3b8;
    }

    /* ── Submit Button ── */
    .btn-update {
      background: #D85A30; color: white; border: none;
      border-radius: 6px; padding: 10px 0;
      font-size: 14px; font-weight: 600;
      width: 100%; cursor: pointer;
      transition: background .2s;
    }
    .btn-update:hover { background: #c04a22; }

    /* ── Back Button ── */
    .btn-back {
      border: 1px solid #dee2e6;
      color: #475569; background: white;
      border-radius: 6px; padding: 5px 14px;
      font-size: 13px; text-decoration: none;
      font-weight: 500;
    }
    .btn-back:hover { background: #f8fafc; color: #475569; }

    /* ── Role Badge ── */
    .role-badge {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
      background: #e8f0fe;
      color: #1a3a6b;
    }
  </style>
</head>
<body>

<%- include('../partials/sidebar') %>

<div class="main-wrapper">
  <%- include('../partials/topbar') %>
  <div class="content-area">

    <!-- Page wrapper centered -->
    <div style="max-width: 520px;">

      <!-- Header Bar -->
      <div class="header-bar mb-0">
        <span class="title">✏️ Edit User</span>
        <% if (currentRole === 'admin') { %>
          <a href="/users" class="btn-back">← Back</a>
        <% } else { %>
          <a href="/dashboard" class="btn-back">← Back</a>
        <% } %>
      </div>

      <!-- Form Card -->
      <div class="form-card">
        <form action="/users/<%= user._id %>/edit" method="POST" id="editForm">

          <% if (currentRole === 'admin') { %>

            <div class="mb-3">
              <label class="form-label-custom">Full Name</label>
              <input type="text" name="name" class="form-control form-control-sm"
                value="<%= user.name %>" placeholder="Enter full name" required>
            </div>

            <div class="mb-3">
              <label class="form-label-custom">Username</label>
              <input type="text" name="username" class="form-control form-control-sm"
                value="<%= user.username %>" placeholder="Enter username" required>
            </div>

            <div class="mb-3">
              <label class="form-label-custom">Password</label>
              <div class="input-group input-group-sm">
                <input type="password" id="password" name="password"
                  class="form-control" value="<%= user.password %>">
                <button class="btn btn-outline-secondary" type="button" onclick="togglePassword()">
                  <i id="eyeIcon" class="fa-solid fa-eye"></i>
                </button>
              </div>
            </div>

            <div class="mb-4">
              <label class="form-label-custom">Role</label>
              <select name="role" class="form-select form-select-sm">
                <option value="booking_agent" <%= user.role === 'Booking Agent' ? 'selected' : '' %>>🎫 Booking Agent</option>
                <option value="admin"   <%= user.role === 'admin'   ? 'selected' : '' %>>🛡️ Admin</option>
              </select>
            </div>

          <% } else { %>

            <div class="mb-3">
              <label class="form-label-custom">Full Name</label>
              <input type="text" name="name" class="form-control form-control-sm"
                value="<%= user.name %>" readonly>
            </div>

            <div class="mb-3">
              <label class="form-label-custom">Username</label>
              <input type="text" name="username" class="form-control form-control-sm"
                value="<%= user.username %>" readonly>
            </div>

            <div class="mb-4">
              <label class="form-label-custom">New Password</label>
              <div class="input-group input-group-sm">
                <input type="password" id="password" name="password"
                  class="form-control" value="<%= user.password %>" required>
                <button class="btn btn-outline-secondary" type="button" onclick="togglePassword()">
                  <i id="eyeIcon" class="fa-solid fa-eye"></i>
                </button>
              </div>
            </div>

          <% } %>

          <button type="button" onclick="submitEdit()" class="btn-update">
            <% if (currentRole === 'admin') { %>✅ Update User<% } else { %>🔒 Update Password<% } %>
          </button>

        </form>
      </div>

    </div>

  </div>
</div>

<script>
  function togglePassword() {
    const input = document.getElementById("password");
    const icon  = document.getElementById("eyeIcon");
    if (input.type === "password") {
      input.type = "text";
      icon.classList.replace("fa-eye", "fa-eye-slash");
    } else {
      input.type = "password";
      icon.classList.replace("fa-eye-slash", "fa-eye");
    }
  }

  function submitEdit() {
    Swal.fire({
      icon: 'success',
      title: 'Updated successfully',
      timer: 1200,
      showConfirmButton: false
    }).then(() => {
      document.getElementById('editForm').submit();
    });
  }
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
