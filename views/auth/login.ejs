<!DOCTYPE html>
<html lang="ur">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — Alhamd Stationery</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <style>
    body { background: #f0f4f8; }
    .login-card { border-radius: 12px; box-shadow: 0 4px 24px rgba(0,0,0,0.10); }
  </style>
</head>
<body class="min-vh-100 d-flex align-items-center justify-content-center">

<div class="card login-card p-4 p-md-5 w-100" style="max-width:400px;">

  <%# Logo %>
  <div class="text-center mb-4">
    <span class="d-block fs-1 mb-2">🏪</span>
    <h1 class="h5 fw-bold text-dark">Al-Deafah</h1>
    <p class="small text-muted text-uppercase ls-1">Point of Sale System</p>
  </div>

  <%# Flash Messages %>
  <% if (error && error.length > 0) { %>
    <div class="alert alert-danger border-start border-danger border-4 py-2">
      <%= error %>
    </div>
  <% } %>
  <% if (success && success.length > 0) { %>
    <div class="alert alert-success border-start border-success border-4 py-2">
      <%= success %>
    </div>
  <% } %>

  <%# Login Form %>
  <form action="/login" method="POST">

    <div class="mb-3">
      <label for="username" class="form-label small fw-semibold text-secondary">Username</label>
      <input type="text" id="username" name="username"
             class="form-control"
             placeholder="apna username daalen"
             required autofocus autocomplete="username">
    </div>

    <div class="mb-3">
      <label for="password" class="form-label small fw-semibold text-secondary">Password</label>
      <div class="input-group">
        <input type="password" id="password" name="password"
               class="form-control"
               placeholder="••••••••"
               required autocomplete="current-password">
        <button class="btn btn-outline-secondary" type="button" onclick="togglePassword()">
          <i id="eyeIcon" class="fa-solid fa-eye"></i>
        </button>
      </div>
    </div>

    <button type="submit" class="btn btn-primary w-100 fw-semibold mt-1">🔐 Login Karein</button>

  </form>

  <p class="text-center text-muted mt-3 mb-0 small">
    Alhamd POS &copy; <%= new Date().getFullYear() %>
  </p>

</div>

<script>
  function togglePassword() {
    const input = document.getElementById("password");
    const icon  = document.getElementById("eyeIcon");
    if (input.type === "password") {
      input.type = "text";
      icon.classList.replace("fa-eye", "fa-eye-slash");
    } else {
      input.type = "password";
      icon.classList.replace("fa-eye-slash", "fa-eye");
    }
  }
</script>

</body>
</html>
