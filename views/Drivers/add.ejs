<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title><%= title %> — TransPort Pro</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    /* ── Page Header ── */
    .page-header {
      display: flex; align-items: center;
      gap: 12px; margin-bottom: 24px;
    }
    .btn-back {
      border: 1px solid #dee2e6; color: #475569; background: white;
      border-radius: 6px; padding: 5px 14px; font-size: 13px;
      text-decoration: none; font-weight: 500;
      display: inline-flex; align-items: center; gap: 5px;
    }
    .btn-back:hover { background: #f8fafc; color: #475569; }
    .page-title { font-size: 18px; font-weight: 700; color: #1a1a1a; margin: 0; }

    /* ── Section Cards ── */
    .section-card {
      background: white; border-radius: 10px;
      border: 1px solid #dee2e6; overflow: hidden; margin-bottom: 18px;
    }
    .section-header {
      background: #D85A30; color: white;
      padding: 0 20px; height: 46px;
      display: flex; align-items: center;
      font-size: 14px; font-weight: 600; gap: 8px;
    }
    .section-body { padding: 20px; }

    /* ── Form Elements ── */
    .form-label {
      font-size: 12px; font-weight: 600;
      color: #374151; margin-bottom: 5px;
    }
    .form-label .req { color: #D85A30; margin-left: 2px; }
    .form-control, .form-select {
      border: 1px solid #dee2e6; border-radius: 7px;
      font-size: 13px; padding: 8px 11px;
      color: #1a1a1a; background: #fafafa;
      transition: border-color .15s, background .15s;
    }
    .form-control:focus, .form-select:focus {
      border-color: #D85A30; background: white;
      box-shadow: 0 0 0 3px rgba(216,90,48,.1); outline: none;
    }
    .form-control::placeholder { color: #b0b8c1; }

    /* ── Input with icon ── */
    .input-wrap { position: relative; }
    .input-wrap .input-icon {
      position: absolute; left: 11px; top: 50%;
      transform: translateY(-50%);
      font-size: 14px; pointer-events: none;
    }
    .input-wrap .form-control,
    .input-wrap .form-select { padding-left: 34px; }

    /* ── Salary field ── */
    .salary-field { background: #f0fdf4 !important; color: #15803d !important; font-weight: 600; }
    .salary-field:focus { border-color: #16a34a !important; box-shadow: 0 0 0 3px rgba(22,163,74,.1) !important; }

    /* ── Photo upload ── */
    .photo-upload-wrap {
      display: flex; flex-direction: column; align-items: center;
      gap: 12px;
    }
    .photo-circle {
      width: 100px; height: 100px; border-radius: 50%;
      border: 3px dashed #dee2e6; background: #fafafa;
      display: flex; align-items: center; justify-content: center;
      font-size: 36px; overflow: hidden; position: relative;
      transition: border-color .15s;
    }
    .photo-circle:hover { border-color: #D85A30; }
    .photo-circle img {
      width: 100%; height: 100%; object-fit: cover;
      display: none; border-radius: 50%;
    }
    .photo-circle .ph-icon { transition: opacity .15s; }
    .upload-btn-label {
      font-size: 12px; color: #D85A30; font-weight: 600;
      cursor: pointer; text-decoration: underline;
    }
    .upload-hint { font-size: 11px; color: #94a3b8; }

    /* ── Buttons ── */
    .btn-submit {
      background: #D85A30; color: white; border: none;
      border-radius: 7px; padding: 11px 36px;
      font-size: 14px; font-weight: 600; cursor: pointer;
      display: inline-flex; align-items: center; gap: 7px;
      transition: background .15s;
    }
    .btn-submit:hover { background: #b94a24; }
    .btn-cancel {
      border: 1px solid #dee2e6; color: #475569; background: white;
      border-radius: 7px; padding: 11px 20px;
      font-size: 14px; text-decoration: none; font-weight: 500;
    }
    .btn-cancel:hover { background: #f8fafc; color: #475569; }
  </style>
</head>
<body>
<% locals.currentPath = '/drivers'; %>
<%- include('../partials/sidebar') %>
<div class="main-wrapper">
  <%- include('../partials/topbar') %>
  <div class="content-area">
    <%- include('../partials/flash') %>

    <div class="row justify-content-center">
      <div class="col-12 col-xl-10">

        <!-- Page Header -->
        <div class="page-header">
          <a href="/drivers" class="btn-back">← Back</a>
          <h5 class="page-title">Add New Driver</h5>
        </div>

        <form action="/drivers" method="POST" enctype="multipart/form-data">

          <!-- ── Personal Information ── -->
          <div class="section-card">
            <div class="section-header">👤 Personal Information</div>
            <div class="section-body">
              <div class="row g-3">

                <div class="col-md-4">
                  <label class="form-label">Full Name <span class="req">*</span></label>
                  <div class="input-wrap">
                    <span class="input-icon">👤</span>
                    <input type="text" name="name" class="form-control"
                      placeholder="Driver full name" required>
                  </div>
                </div>

                <div class="col-md-4">
                  <label class="form-label">Father Name</label>
                  <div class="input-wrap">
                    <span class="input-icon">👨</span>
                    <input type="text" name="fatherName" class="form-control"
                      placeholder="Father's name">
                  </div>
                </div>

                <div class="col-md-4">
                  <label class="form-label">Date of Birth</label>
                  <div class="input-wrap">
                    <span class="input-icon">🎂</span>
                    <input type="date" name="dateOfBirth" class="form-control">
                  </div>
                </div>

                <div class="col-md-4">
                  <label class="form-label">Gender</label>
                  <div class="input-wrap">
                    <span class="input-icon">⚧️</span>
                    <select name="gender" class="form-select">
                      <option value="male">Male</option>
                      <option value="female">Female</option>
                      <option value="other">Other</option>
                    </select>
                  </div>
                </div>

                <div class="col-md-4">
                  <label class="form-label">CNIC <span class="req">*</span></label>
                  <div class="input-wrap">
                    <span class="input-icon">🪪</span>
                    <input type="text" name="cnic" class="form-control"
                      placeholder="35202-1234567-1" required>
                  </div>
                </div>

                <div class="col-md-4">
                  <label class="form-label">Marital Status</label>
                  <div class="input-wrap">
                    <span class="input-icon">💍</span>
                    <select name="maritalStatus" class="form-select">
                      <option value="">Select...</option>
                      <option value="single">Single</option>
                      <option value="married">Married</option>
                      <option value="divorced">Divorced</option>
                      <option value="widowed">Widowed</option>
                    </select>
                  </div>
                </div>

              </div>
            </div>
          </div>

          <!-- ── Contact Information ── -->
          <div class="section-card">
            <div class="section-header">📞 Contact Information</div>
            <div class="section-body">
              <div class="row g-3">

                <div class="col-md-4">
                  <label class="form-label">Phone <span class="req">*</span></label>
                  <div class="input-wrap">
                    <span class="input-icon">📞</span>
                    <input type="text" name="phone" class="form-control"
                      placeholder="03XX-XXXXXXX" required>
                  </div>
                </div>

                <div class="col-md-4">
                  <label class="form-label">WhatsApp</label>
                  <div class="input-wrap">
                    <span class="input-icon">💬</span>
                    <input type="text" name="whatsapp" class="form-control"
                      placeholder="03XX-XXXXXXX">
                  </div>
                </div>

                <div class="col-md-4">
                  <label class="form-label">Email</label>
                  <div class="input-wrap">
                    <span class="input-icon">✉️</span>
                    <input type="email" name="email" class="form-control"
                      placeholder="email@example.com">
                  </div>
                </div>

                <div class="col-md-6">
                  <label class="form-label">Address</label>
                  <div class="input-wrap">
                    <span class="input-icon">📍</span>
                    <input type="text" name="address" class="form-control"
                      placeholder="Full address">
                  </div>
                </div>

                <div class="col-md-3">
                  <label class="form-label">City</label>
                  <div class="input-wrap">
                    <span class="input-icon">🏙️</span>
                    <input type="text" name="city" class="form-control"
                      placeholder="Lahore" value="Lahore">
                  </div>
                </div>

              </div>
            </div>
          </div>

          <!-- ── License Details ── -->
          <div class="section-card">
            <div class="section-header">🪪 License Details</div>
            <div class="section-body">
              <div class="row g-3">

                <div class="col-md-4">
                  <label class="form-label">License Number <span class="req">*</span></label>
                  <div class="input-wrap">
                    <span class="input-icon">📋</span>
                    <input type="text" name="licenseNumber" class="form-control"
                      placeholder="License number" required>
                  </div>
                </div>

                <div class="col-md-4">
                  <label class="form-label">License Type</label>
                  <div class="input-wrap">
                    <span class="input-icon">🏷️</span>
                    <select name="licenseType" class="form-select">
                      <option value="LTV">LTV (Light Transport)</option>
                      <option value="HTV">HTV (Heavy Transport)</option>
                      <option value="MC">Motorcycle</option>
                      <option value="PSV">PSV (Public Service)</option>
                      <option value="other">Other</option>
                    </select>
                  </div>
                </div>

                <div class="col-md-4">
                  <label class="form-label">License Expiry Date</label>
                  <div class="input-wrap">
                    <span class="input-icon">📅</span>
                    <input type="date" name="licenseExpiry" class="form-control">
                  </div>
                </div>

                <div class="col-md-4">
                  <label class="form-label">Experience (Years)</label>
                  <div class="input-wrap">
                    <span class="input-icon">⭐</span>
                    <input type="number" name="experienceYears" class="form-control"
                      placeholder="0" min="0" max="50">
                  </div>
                </div>

                <div class="col-md-4">
                  <label class="form-label">Joining Date</label>
                  <div class="input-wrap">
                    <span class="input-icon">📅</span>
                    <input type="date" name="joiningDate" class="form-control"
                      value="<%= new Date().toISOString().split('T')[0] %>">
                  </div>
                </div>

              </div>
            </div>
          </div>

          <!-- ── Salary Details ── -->
          <div class="section-card">
            <div class="section-header">💰 Salary Details</div>
            <div class="section-body">
              <div class="row g-3">

                <div class="col-md-4">
                  <label class="form-label">Salary (SAR)</label>
                  <div class="input-wrap">
                    <span class="input-icon">💰</span>
                    <input type="number" name="salary" class="form-control salary-field"
                      placeholder="0" min="0">
                  </div>
                </div>

                <div class="col-md-4">
                  <label class="form-label">Salary Type</label>
                  <div class="input-wrap">
                    <span class="input-icon">📊</span>
                    <select name="salaryType" class="form-select">
                      <option value="fixed">Fixed Monthly</option>
                      <option value="per-trip">Per Trip</option>
                      <option value="per-day">Per Day</option>
                    </select>
                  </div>
                </div>

              </div>
            </div>
          </div>

          <!-- ── Emergency Contact ── -->
          <div class="section-card">
            <div class="section-header">🆘 Emergency Contact</div>
            <div class="section-body">
              <div class="row g-3">

                <div class="col-md-4">
                  <label class="form-label">Name</label>
                  <div class="input-wrap">
                    <span class="input-icon">👤</span>
                    <input type="text" name="emergencyContactName" class="form-control"
                      placeholder="Contact name">
                  </div>
                </div>

                <div class="col-md-4">
                  <label class="form-label">Phone</label>
                  <div class="input-wrap">
                    <span class="input-icon">📞</span>
                    <input type="text" name="emergencyContactPhone" class="form-control"
                      placeholder="03XX-XXXXXXX">
                  </div>
                </div>

                <div class="col-md-4">
                  <label class="form-label">Relation</label>
                  <div class="input-wrap">
                    <span class="input-icon">🤝</span>
                    <input type="text" name="emergencyRelation" class="form-control"
                      placeholder="e.g. Brother, Wife">
                  </div>
                </div>

              </div>
            </div>
          </div>

          <!-- ── Photo & Notes ── -->
          <div class="section-card">
            <div class="section-header">📷 Photo & Notes</div>
            <div class="section-body">
              <div class="row g-3">

                <div class="col-md-4">
                  <label class="form-label">Driver Photo</label>
                  <div class="photo-upload-wrap">
                    <div class="photo-circle" id="photoCircle">
                      <span class="ph-icon" id="phIcon">👤</span>
                      <img id="photoPreview" alt="preview">
                    </div>
                    <label for="driverImageInput" class="upload-btn-label">Click to upload photo</label>
                    <span class="upload-hint">JPG, PNG — max 5MB</span>
                    <input type="file" name="driverImage" id="driverImageInput"
                      accept="image/*" style="display:none;" onchange="previewPhoto(this)">
                  </div>
                </div>

                <div class="col-md-8">
                  <label class="form-label">Notes <small style="font-weight:400;color:#94a3b8;">(optional)</small></label>
                  <textarea name="notes" class="form-control" rows="6"
                    placeholder="Any additional information about this driver..."></textarea>
                </div>

              </div>
            </div>
          </div>

          <!-- ── Actions ── -->
          <div class="d-flex align-items-center gap-2 mb-4">
            <button type="submit" class="btn-submit">✅ Add Driver</button>
            <a href="/drivers" class="btn-cancel">Cancel</a>
          </div>

        </form>
      </div>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function previewPhoto(input) {
    if (input.files && input.files[0]) {
      const reader = new FileReader();
      reader.onload = function(e) {
        const img = document.getElementById('photoPreview');
        const icon = document.getElementById('phIcon');
        img.src = e.target.result;
        img.style.display = 'block';
        icon.style.display = 'none';
      };
      reader.readAsDataURL(input.files[0]);
    }
  }
</script>
</body>
</html>
