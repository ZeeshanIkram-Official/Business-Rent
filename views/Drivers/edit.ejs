<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title><%= title %> — TransPort Pro</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    /* ── Page Header ── */
    .page-header {
      display: flex; align-items: center;
      gap: 12px; margin-bottom: 24px;
    }
    .btn-back {
      border: 1px solid #dee2e6; color: #475569; background: white;
      border-radius: 6px; padding: 5px 14px; font-size: 13px;
      text-decoration: none; font-weight: 500;
      display: inline-flex; align-items: center; gap: 5px;
    }
    .btn-back:hover { background: #f8fafc; color: #475569; }
    .page-title { font-size: 18px; font-weight: 700; color: #1a1a1a; margin: 0; }

    /* ── Section Cards ── */
    .section-card {
      background: white; border-radius: 10px;
      border: 1px solid #dee2e6; overflow: hidden; margin-bottom: 18px;
    }
    .section-header {
      background: #D85A30; color: white;
      padding: 0 20px; height: 46px;
      display: flex; align-items: center;
      font-size: 14px; font-weight: 600; gap: 8px;
    }
    .section-body { padding: 20px; }

    /* ── Form Elements ── */
    .form-label {
      font-size: 12px; font-weight: 600;
      color: #374151; margin-bottom: 5px;
    }
    .form-label .req { color: #D85A30; margin-left: 2px; }
    .form-control, .form-select {
      border: 1px solid #dee2e6; border-radius: 7px;
      font-size: 13px; padding: 8px 11px;
      color: #1a1a1a; background: #fafafa;
      transition: border-color .15s, background .15s;
    }
    .form-control:focus, .form-select:focus {
      border-color: #D85A30; background: white;
      box-shadow: 0 0 0 3px rgba(216,90,48,.1); outline: none;
    }
    .form-control::placeholder { color: #b0b8c1; }

    /* ── Input with icon ── */
    .input-wrap { position: relative; }
    .input-wrap .input-icon {
      position: absolute; left: 11px; top: 50%;
      transform: translateY(-50%);
      font-size: 14px; pointer-events: none;
    }
    .input-wrap .form-control,
    .input-wrap .form-select { padding-left: 34px; }

    /* ── Active toggle ── */
    .toggle-wrap {
      display: flex; align-items: center; gap: 10px;
      background: #f8fafc; border: 1px solid #dee2e6;
      border-radius: 7px; padding: 9px 14px; cursor: pointer;
      margin-top: 2px;
    }
    .toggle-wrap input[type="checkbox"] { display: none; }
    .toggle-track {
      width: 38px; height: 20px; border-radius: 10px;
      background: #dee2e6; position: relative;
      transition: background .2s; flex-shrink: 0;
    }
    .toggle-track::after {
      content: ''; position: absolute;
      left: 3px; top: 3px;
      width: 14px; height: 14px; border-radius: 50%;
      background: white; transition: left .2s;
      box-shadow: 0 1px 3px rgba(0,0,0,.2);
    }
    .toggle-wrap.active .toggle-track { background: #D85A30; }
    .toggle-wrap.active .toggle-track::after { left: 21px; }
    .toggle-label { font-size: 13px; font-weight: 500; color: #374151; }

    /* ── Salary field ── */
    .salary-field { background: #f0fdf4 !important; color: #15803d !important; font-weight: 600; }
    .salary-field:focus { border-color: #16a34a !important; box-shadow: 0 0 0 3px rgba(22,163,74,.1) !important; }

    /* ── Driver photo ── */
    .driver-photo {
      width: 80px; height: 80px; border-radius: 50%;
      object-fit: cover; border: 3px solid #fde8dd;
      display: block; margin-bottom: 10px;
    }
    .file-hint { font-size: 11px; color: #94a3b8; margin-top: 4px; }

    /* ── Buttons ── */
    .btn-submit {
      background: #D85A30; color: white; border: none;
      border-radius: 7px; padding: 11px 36px;
      font-size: 14px; font-weight: 600; cursor: pointer;
      display: inline-flex; align-items: center; gap: 7px;
      transition: background .15s;
    }
    .btn-submit:hover { background: #b94a24; }
    .btn-cancel {
      border: 1px solid #dee2e6; color: #475569; background: white;
      border-radius: 7px; padding: 11px 20px;
      font-size: 14px; text-decoration: none; font-weight: 500;
    }
    .btn-cancel:hover { background: #f8fafc; color: #475569; }
    .btn-deactivate {
      border: 1px solid #fca5a5; color: #dc2626; background: white;
      border-radius: 7px; padding: 11px 20px;
      font-size: 14px; font-weight: 500; cursor: pointer;
      display: inline-flex; align-items: center; gap: 6px;
      transition: background .15s;
    }
    .btn-deactivate:hover { background: #fee2e2; }
  </style>
</head>
<body>
<% locals.currentPath = '/drivers'; %>
<%- include('../partials/sidebar') %>
<div class="main-wrapper">
  <%- include('../partials/topbar') %>
  <div class="content-area">
    <%- include('../partials/flash') %>

    <div class="row justify-content-center">
      <div class="col-12 col-xl-10">

        <!-- Page Header -->
        <div class="page-header">
          <a href="/drivers/<%= driver._id %>" class="btn-back">← Back</a>
          <h5 class="page-title">Edit Driver — <%= driver.name %></h5>
        </div>

        <form action="/drivers/<%= driver._id %>?_method=PUT" method="POST" enctype="multipart/form-data">

          <!-- ── Personal Information ── -->
          <div class="section-card">
            <div class="section-header">👤 Personal Information</div>
            <div class="section-body">
              <div class="row g-3">

                <div class="col-md-4">
                  <label class="form-label">Full Name <span class="req">*</span></label>
                  <div class="input-wrap">
                    <span class="input-icon">👤</span>
                    <input type="text" name="name" class="form-control"
                      value="<%= driver.name %>" required>
                  </div>
                </div>

                <div class="col-md-4">
                  <label class="form-label">Father Name</label>
                  <div class="input-wrap">
                    <span class="input-icon">👨</span>
                    <input type="text" name="fatherName" class="form-control"
                      value="<%= driver.fatherName || '' %>">
                  </div>
                </div>

                <div class="col-md-4">
                  <label class="form-label">CNIC <span class="req">*</span></label>
                  <div class="input-wrap">
                    <span class="input-icon">🪪</span>
                    <input type="text" name="cnic" class="form-control"
                      value="<%= driver.cnic || '' %>" placeholder="xxxxx-xxxxxxx-x" required>
                  </div>
                </div>

                <div class="col-md-4">
                  <label class="form-label">Phone <span class="req">*</span></label>
                  <div class="input-wrap">
                    <span class="input-icon">📞</span>
                    <input type="text" name="phone" class="form-control"
                      value="<%= driver.phone %>" required>
                  </div>
                </div>

                <div class="col-md-4">
                  <label class="form-label">WhatsApp</label>
                  <div class="input-wrap">
                    <span class="input-icon">💬</span>
                    <input type="text" name="whatsapp" class="form-control"
                      value="<%= driver.whatsapp || '' %>">
                  </div>
                </div>

                <div class="col-md-4">
                  <label class="form-label">City</label>
                  <div class="input-wrap">
                    <span class="input-icon">🏙️</span>
                    <input type="text" name="city" class="form-control"
                      value="<%= driver.city || 'Lahore' %>">
                  </div>
                </div>

                <div class="col-md-8">
                  <label class="form-label">Address</label>
                  <div class="input-wrap">
                    <span class="input-icon">📍</span>
                    <input type="text" name="address" class="form-control"
                      value="<%= driver.address || '' %>">
                  </div>
                </div>

                <div class="col-md-4">
                  <label class="form-label">Status</label>
                  <label class="toggle-wrap <%= driver.isActive ? 'active' : '' %>"
                    id="toggleWrap" onclick="toggleActive(this)">
                    <input type="checkbox" name="isActive" id="isActive"
                      <%= driver.isActive ? 'checked' : '' %>>
                    <div class="toggle-track"></div>
                    <span class="toggle-label" id="toggleLabel">
                      <%= driver.isActive ? 'Active Driver' : 'Inactive Driver' %>
                    </span>
                  </label>
                </div>

              </div>
            </div>
          </div>

          <!-- ── License Details ── -->
          <div class="section-card">
            <div class="section-header">🪪 License Details</div>
            <div class="section-body">
              <div class="row g-3">

                <div class="col-md-4">
                  <label class="form-label">License Number <span class="req">*</span></label>
                  <div class="input-wrap">
                    <span class="input-icon">📋</span>
                    <input type="text" name="licenseNumber" class="form-control"
                      value="<%= driver.licenseNumber %>" required>
                  </div>
                </div>

                <div class="col-md-4">
                  <label class="form-label">License Type</label>
                  <div class="input-wrap">
                    <span class="input-icon">🏷️</span>
                    <select name="licenseType" class="form-select">
                      <% ['LTV','HTV','MC','PSV','other'].forEach(t => { %>
                      <option value="<%= t %>" <%= driver.licenseType === t ? 'selected' : '' %>><%= t %></option>
                      <% }) %>
                    </select>
                  </div>
                </div>

                <div class="col-md-4">
                  <label class="form-label">License Expiry</label>
                  <div class="input-wrap">
                    <span class="input-icon">📅</span>
                    <input type="date" name="licenseExpiry" class="form-control"
                      value="<%= driver.licenseExpiry ? moment(driver.licenseExpiry).format('YYYY-MM-DD') : '' %>">
                  </div>
                </div>

                <div class="col-md-4">
                  <label class="form-label">Experience (Years)</label>
                  <div class="input-wrap">
                    <span class="input-icon">⭐</span>
                    <input type="number" name="experienceYears" class="form-control"
                      value="<%= driver.experienceYears || 0 %>" min="0">
                  </div>
                </div>

                <div class="col-md-4">
                  <label class="form-label">Salary (SAR)</label>
                  <div class="input-wrap">
                    <span class="input-icon">💰</span>
                    <input type="number" name="salary" class="form-control salary-field"
                      value="<%= driver.salary || 0 %>" min="0">
                  </div>
                </div>

                <div class="col-md-4">
                  <label class="form-label">Salary Type</label>
                  <div class="input-wrap">
                    <span class="input-icon">📊</span>
                    <select name="salaryType" class="form-select">
                      <option value="fixed"    <%= driver.salaryType === 'fixed'    ? 'selected' : '' %>>Fixed Monthly</option>
                      <option value="per-trip" <%= driver.salaryType === 'per-trip' ? 'selected' : '' %>>Per Trip</option>
                      <option value="per-day"  <%= driver.salaryType === 'per-day'  ? 'selected' : '' %>>Per Day</option>
                    </select>
                  </div>
                </div>

              </div>
            </div>
          </div>

          <!-- ── Emergency Contact ── -->
          <div class="section-card">
            <div class="section-header">🆘 Emergency Contact</div>
            <div class="section-body">
              <div class="row g-3">

                <div class="col-md-4">
                  <label class="form-label">Name</label>
                  <div class="input-wrap">
                    <span class="input-icon">👤</span>
                    <input type="text" name="emergencyContactName" class="form-control"
                      value="<%= driver.emergencyContactName || '' %>">
                  </div>
                </div>

                <div class="col-md-4">
                  <label class="form-label">Phone</label>
                  <div class="input-wrap">
                    <span class="input-icon">📞</span>
                    <input type="text" name="emergencyContactPhone" class="form-control"
                      value="<%= driver.emergencyContactPhone || '' %>">
                  </div>
                </div>

                <div class="col-md-4">
                  <label class="form-label">Relation</label>
                  <div class="input-wrap">
                    <span class="input-icon">🤝</span>
                    <input type="text" name="emergencyRelation" class="form-control"
                      value="<%= driver.emergencyRelation || '' %>">
                  </div>
                </div>

              </div>
            </div>
          </div>

          <!-- ── Photo & Notes ── -->
          <div class="section-card">
            <div class="section-header">📷 Photo & Notes</div>
            <div class="section-body">
              <div class="row g-3">

                <div class="col-md-4">
                  <label class="form-label">Driver Photo</label>
                  <% if (driver.driverImage) { %>
                    <img src="<%= driver.driverImage %>" class="driver-photo" alt="Driver photo">
                  <% } %>
                  <input type="file" name="driverImage" class="form-control" accept="image/*">
                  <p class="file-hint">Leave empty to keep existing photo</p>
                </div>

                <div class="col-md-8">
                  <label class="form-label">Notes <small style="font-weight:400;color:#94a3b8;">(optional)</small></label>
                  <textarea name="notes" class="form-control" rows="5"
                    placeholder="Any additional notes about this driver..."><%= driver.notes || '' %></textarea>
                </div>

              </div>
            </div>
          </div>

          <!-- ── Actions ── -->
          <div class="d-flex align-items-center gap-2 mb-4 flex-wrap">
            <button type="submit" class="btn-submit">💾 Update Driver</button>
            <a href="/drivers/<%= driver._id %>" class="btn-cancel">Cancel</a>
            <% if (currentRole === 'admin') { %>
            <div class="ms-auto">
              <form action="/drivers/<%= driver._id %>?_method=DELETE" method="POST"
                    onsubmit="return confirm('Are you sure you want to deactivate this driver?')">
                <button type="submit" class="btn-deactivate">⛔ Deactivate</button>
              </form>
            </div>
            <% } %>
          </div>

        </form>
      </div>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function toggleActive(wrap) {
    const cb = wrap.querySelector('input[type="checkbox"]');
    const label = document.getElementById('toggleLabel');
    cb.checked = !cb.checked;
    if (cb.checked) {
      wrap.classList.add('active');
      label.textContent = 'Active Driver';
    } else {
      wrap.classList.remove('active');
      label.textContent = 'Inactive Driver';
    }
  }
</script>
</body>
</html>
