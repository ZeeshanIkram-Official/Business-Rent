<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title><%= title %> — TransPort Pro</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    /* ── Header Bar ── */
    .header-bar {
      background: #D85A30;
      color: white;
      padding: 0 20px;
      height: 52px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-radius: 10px 10px 0 0;
    }
    .header-bar .title { font-size: 16px; font-weight: 600; }

    /* ── Stat Cards ── */
    .stat-card {
      background: white;
      border-radius: 10px;
      border: 1px solid #dee2e6;
      padding: 14px 16px;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .stat-icon {
      width: 40px; height: 40px; border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px; flex-shrink: 0;
    }
    .stat-icon.blue   { background: #e8f0fe; }
    .stat-icon.green  { background: #e8f8ee; }
    .stat-icon.red    { background: #fdecea; }
    .stat-icon.orange { background: #fff0e8; }
    .stat-value { font-size: 22px; font-weight: 700; color: #1a1a1a; line-height: 1; }
    .stat-label { font-size: 12px; color: #6c757d; margin-top: 2px; }
    .stat-sub   { font-size: 11px; color: #94a3b8; margin-top: 2px; }

    /* ── Table Card ── */
    .table-card {
      border: 1px solid #dee2e6;
      border-top: none;
      border-radius: 0 0 10px 10px;
      overflow: hidden;
      background: white;
    }

    /* ── Filter Bar ── */
    .filter-bar {
      padding: 14px 20px;
      background: #f8fafc;
      border-bottom: 1px solid #e2e8f0;
    }

    /* ── Table ── */
    .table-wrap { overflow-x: auto; }
    .pro-table { width: 100%; border-collapse: collapse; }
    .pro-table thead th {
      font-size: 11px; font-weight: 600;
      color: #6c757d; background: white;
      border-bottom: 1px solid #dee2e6;
      padding: 12px 16px;
      white-space: nowrap;
      text-transform: uppercase;
      letter-spacing: .4px;
    }
    .pro-table tbody td {
      padding: 13px 16px; font-size: 14px;
      vertical-align: middle;
      border-bottom: 1px solid #f1f1f1;
    }
    .pro-table tbody tr:last-child td { border-bottom: none; }
    .pro-table tbody tr:hover { background: #fafafa; }

    /* ── Badges ── */
    .badge-status {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
      text-transform: capitalize;
    }
    .badge-available  { background: #d1e7dd; color: #0a3622; }
    .badge-cancelled  { background: #f8d7da; color: #842029; }

    /* ── Avatar ── */
    .avatar-sm {
      width: 36px; height: 36px;
      border-radius: 50%; object-fit: cover;
      border: 1px solid #dee2e6;
    }
    .avatar-placeholder-sm {
      width: 36px; height: 36px;
      border-radius: 50%;
      background: #f1f5f9;
      display: flex; align-items: center; justify-content: center;
      font-size: 16px; flex-shrink: 0;
      border: 1px solid #dee2e6;
    }

    /* ── Buttons ── */
    .btn-add-driver {
      background: #1a1a1a; color: white; border: none;
      border-radius: 6px; padding: 0 14px; height: 34px;
      font-size: 13px; cursor: pointer;
      display: inline-flex; align-items: center; gap: 6px;
      text-decoration: none;
    }
    .btn-add-driver:hover { background: #333; color: white; }

    .btn-xs {
      padding: 3px 10px; font-size: 12px;
      border-radius: 5px; line-height: 1.5;
    }
    .btn-view-xs {
      border: 1px solid #D85A30;
      color: #D85A30; background: white;
      border-radius: 5px; padding: 3px 10px;
      font-size: 12px; text-decoration: none;
      font-weight: 500;
    }
    .btn-view-xs:hover { background: #fff0e8; color: #D85A30; }
    .btn-edit-xs {
      border: 1px solid #dee2e6;
      color: #475569; background: white;
      border-radius: 5px; padding: 3px 10px;
      font-size: 12px; text-decoration: none;
      font-weight: 500;
    }
    .btn-edit-xs:hover { background: #f8fafc; color: #475569; }

    /* ── Delete Button ── */
    .btn-delete-xs {
      border: 1px solid #f8d7da;
      color: #842029; background: white;
      border-radius: 5px; padding: 3px 10px;
      font-size: 12px; font-weight: 500;
      cursor: pointer;
    }
    .btn-delete-xs:hover { background: #f8d7da; color: #842029; }

    /* ── Confirm Modal ── */
    .modal-confirm .modal-header {
      background: #D85A30; color: white;
      border-radius: 10px 10px 0 0;
    }
    .modal-confirm .modal-content { border-radius: 10px; border: none; }
    .modal-confirm .btn-danger { background: #842029; border: none; }

    .empty-state { text-align: center; padding: 48px 20px; color: #94a3b8; }
    .empty-icon  { font-size: 48px; margin-bottom: 10px; }
  </style>
</head>
<body>
<% locals.currentPath = '/drivers'; %>
<%- include('../partials/sidebar') %>
<div class="main-wrapper">
  <%- include('../partials/topbar') %>
  <div class="content-area">
    <%- include('../partials/flash') %>

    <!-- Stats -->
    <div class="row g-3 mb-4">
      <div class="col-6 col-md-3">
        <div class="stat-card"><div class="stat-icon blue">👥</div><div><div class="stat-value"><%= stats.total %></div><div class="stat-label">Total Drivers</div></div></div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-card"><div class="stat-icon green">✅</div><div><div class="stat-value"><%= stats.active %></div><div class="stat-label">Active</div></div></div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-card"><div class="stat-icon red">⛔</div><div><div class="stat-value"><%= stats.inactive %></div><div class="stat-label">Inactive</div></div></div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-card"><div class="stat-icon orange">⚠️</div><div><div class="stat-value"><%= stats.expiring %></div><div class="stat-label">License Expiring</div><div class="stat-sub">within 30 days</div></div></div>
      </div>
    </div>

    <!-- Header Bar -->
    <div class="header-bar mb-0">
      <span class="title">👤 Driver Management</span>
      <% if (currentRole === 'admin') { %>
        <a href="/drivers/add" class="btn-add-driver">⊕ Add Driver</a>
      <% } %>
    </div>

    <!-- Table Card -->
    <div class="table-card">

      <!-- Filter Bar -->
      <div class="filter-bar">
        <form method="GET" class="row g-2 align-items-end">
          <div class="col-md-5">
            <input type="text" name="search" class="form-control form-control-sm"
              placeholder="Search by name, phone, CNIC, license..." value="<%= search %>">
          </div>
          <div class="col-md-3">
            <select name="status" class="form-select form-select-sm">
              <option value="">All Drivers</option>
              <option value="active"   <%= status === 'active'   ? 'selected' : '' %>>Active Only</option>
              <option value="inactive" <%= status === 'inactive' ? 'selected' : '' %>>Inactive Only</option>
            </select>
          </div>
          <div class="col-md-2">
            <button class="btn btn-sm w-100" style="background:#D85A30;color:white;border:none;">🔍 Search</button>
          </div>
          <div class="col-md-2">
            <a href="/drivers" class="btn btn-outline-secondary btn-sm w-100">Reset</a>
          </div>
        </form>
      </div>

      <!-- Table -->
      <% if (drivers.length === 0) { %>
        <div class="empty-state">
          <div class="empty-icon">👤</div>
          <p>No drivers found</p>
        </div>
      <% } else { %>
      <div class="table-wrap">
        <table class="pro-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Driver</th>
              <th>Phone</th>
              <th>CNIC</th>
              <th>License</th>
              <th>License Expiry</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% drivers.forEach(function(d, i) {
              const isExpired  = d.licenseExpiry && new Date(d.licenseExpiry) < new Date();
              const isExpiring = d.licenseExpiry && !isExpired && new Date(d.licenseExpiry) <= moment().add(30,'days').toDate();
            %>
            <tr>
              <td class="text-muted" style="font-size:13px;"><%= i + 1 %></td>
              <td>
                <div class="d-flex align-items-center gap-2">
                  <% if (d.driverImage) { %>
                    <img src="<%= d.driverImage %>" class="avatar-sm" alt="<%= d.name %>">
                  <% } else { %>
                    <div class="avatar-placeholder-sm">👤</div>
                  <% } %>
                  <div>
                    <div class="fw-bold" style="font-size:14px;"><%= d.name %></div>
                    <div style="font-size:11px;color:#94a3b8;"><%= d.experienceYears || 0 %> yrs exp</div>
                  </div>
                </div>
              </td>
              <td style="font-size:13px;"><%= d.phone %></td>
              <td style="font-size:13px;"><%= d.cnic || '—' %></td>
              <td style="font-size:13px;">
                <%= d.licenseNumber %>
                <span class="badge bg-secondary ms-1" style="font-size:10px;"><%= d.licenseType %></span>
              </td>
              <td style="font-size:13px;">
                <% if (d.licenseExpiry) { %>
                  <span class="<%= isExpired ? 'text-danger fw-bold' : isExpiring ? 'text-warning fw-bold' : '' %>">
                    <%= moment(d.licenseExpiry).format('DD MMM YYYY') %>
                    <%= isExpired ? '❌ Expired' : isExpiring ? '⚠️ Soon' : '' %>
                  </span>
                <% } else { %>—<% } %>
              </td>
              <td>
                <% if (d.isActive) { %>
                  <span class="badge-status badge-available">● Active</span>
                <% } else { %>
                  <span class="badge-status badge-cancelled">● Inactive</span>
                <% } %>
              </td>
              <td>
                <div class="d-flex gap-1">
                  <a href="/drivers/<%= d._id %>" class="btn-view-xs">View</a>
                  <% if (currentRole === 'admin') { %>
                    <a href="/drivers/<%= d._id %>/edit" class="btn-edit-xs">Edit</a>
                    <button
                      class="btn-delete-xs"
                      onclick="confirmDelete('<%= d._id %>', '<%= d.name %>')">
                      🗑 Delete
                    </button>
                  <% } %>
                </div>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% } %>

    </div><!-- /table-card -->

  </div>
</div>

<!-- ── Delete Confirm Modal ── -->
<div class="modal fade modal-confirm" id="deleteModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h6 class="modal-title fw-bold">🗑 Confirm Delete</h6>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" style="font-size:14px;">
        <p class="mb-1">Kya aap <strong id="driverNameText"></strong> ko permanently delete karna chahte hain?</p>
        <p class="text-danger mb-0" style="font-size:12px;">⚠️ Yeh action undo nahi ho sakta — record hamesha ke liye delete ho jayega.</p>
      </div>
      <div class="modal-footer border-0">
        <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <form id="deleteForm" method="POST" style="display:inline;">
          <input type="hidden" name="_method" value="DELETE">
          <button type="submit" class="btn btn-sm btn-danger">🗑 Delete</button>
        </form>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function confirmDelete(id, name) {
    document.getElementById('driverNameText').textContent = name;
    document.getElementById('deleteForm').action = '/drivers/' + id + '?_method=DELETE';
    new bootstrap.Modal(document.getElementById('deleteModal')).show();
  }
</script>
</body>
</html>
