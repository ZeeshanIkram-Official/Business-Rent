<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Booking <%= booking.bookingId %> — TransPort Pro</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    /* ── Page Header ── */
    .page-header {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 24px;
      flex-wrap: wrap;
    }
    .btn-back {
      border: 1px solid #dee2e6;
      color: #475569; background: white;
      border-radius: 6px; padding: 5px 14px;
      font-size: 13px; text-decoration: none;
      font-weight: 500; display: inline-flex;
      align-items: center; gap: 5px;
      white-space: nowrap;
    }
    .btn-back:hover { background: #f8fafc; color: #475569; }
    .page-title { font-size: 18px; font-weight: 700; color: #1a1a1a; margin: 0; flex: 1; }

    .btn-print {
      border: 1px solid #dee2e6;
      color: #475569; background: white;
      border-radius: 6px; padding: 5px 14px;
      font-size: 13px; text-decoration: none;
      font-weight: 500; display: inline-flex;
      align-items: center; gap: 5px;
    }
    .btn-print:hover { background: #f8fafc; color: #475569; }

    .btn-edit {
      background: #1a1a1a; color: white; border: none;
      border-radius: 6px; padding: 6px 16px;
      font-size: 13px; text-decoration: none;
      font-weight: 500; display: inline-flex;
      align-items: center; gap: 5px;
    }
    .btn-edit:hover { background: #333; color: white; }

    /* ── Status Badges ── */
    .badge-status {
      display: inline-block; padding: 4px 12px;
      border-radius: 20px; font-size: 11px; font-weight: 700;
      text-transform: uppercase; letter-spacing: .4px;
    }
    .badge-pending   { background: #fff9e6; color: #856404; }
    .badge-confirmed { background: #e8f0fe; color: #1a3a6b; }
    .badge-ongoing   { background: #fff0e8; color: #7a2f00; }
    .badge-completed { background: #d1e7dd; color: #0a3622; }
    .badge-cancelled { background: #f8d7da; color: #842029; }
    .badge-paid      { background: #d1e7dd; color: #0a3622; }
    .badge-partial   { background: #fff9e6; color: #856404; }
    .badge-unpaid    { background: #f8d7da; color: #842029; }

    /* ── Section Cards ── */
    .section-card {
      background: white;
      border-radius: 10px;
      border: 1px solid #dee2e6;
      overflow: hidden;
      margin-bottom: 20px;
    }
    .section-header {
      background: #D85A30;
      color: white;
      padding: 0 20px;
      height: 46px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: 14px;
      font-weight: 600;
      gap: 8px;
    }
    .section-header-badge {
      display: inline-block; padding: 3px 10px;
      border-radius: 20px; font-size: 11px; font-weight: 600;
      background: rgba(255,255,255,.2); color: white;
    }
    .section-body { padding: 20px; }

    /* ── Info Boxes ── */
    .info-box {
      background: #f8fafc;
      border-radius: 10px;
      padding: 16px;
      height: 100%;
    }
    .info-box-title {
      font-size: 10px; text-transform: uppercase;
      letter-spacing: .6px; color: #94a3b8;
      margin-bottom: 10px; font-weight: 600;
    }
    .info-box-name { font-size: 15px; font-weight: 700; color: #1a1a1a; }
    .info-box-line { font-size: 13px; color: #64748b; margin-top: 3px; }

    .fleet-plate {
      display: inline-block;
      background: #1a1a1a; color: white;
      font-size: 12px; font-weight: 700;
      padding: 2px 10px; border-radius: 4px;
      letter-spacing: .5px; margin-top: 4px;
    }

    .driver-divider {
      border-top: 1px dashed #e2e8f0;
      margin: 10px 0 8px;
      padding-top: 8px;
    }
    .driver-label { font-size: 10px; color: #94a3b8; text-transform: uppercase; letter-spacing: .5px; margin-bottom: 3px; }

    /* ── Notes Box ── */
    .notes-box {
      background: #fffbeb;
      border-radius: 8px;
      border-left: 3px solid #f59e0b;
      padding: 12px 14px;
      font-size: 13px;
      color: #64748b;
      margin-top: 16px;
    }

    /* ── Payment History ── */
    .payment-item {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      padding: 12px 0;
      border-bottom: 1px solid #f1f5f9;
    }
    .payment-item:last-child { border-bottom: none; }
    .payment-dot {
      width: 10px; height: 10px; border-radius: 50%;
      background: #D85A30; flex-shrink: 0; margin-top: 5px;
    }
    .payment-amount { font-size: 14px; font-weight: 700; color: #1a1a1a; }
    .payment-method {
      display: inline-block; padding: 2px 8px;
      border-radius: 5px; font-size: 10px; font-weight: 600;
      background: #f1f5f9; color: #475569;
      margin-left: 6px; vertical-align: middle;
    }
    .payment-meta { font-size: 12px; color: #94a3b8; margin-top: 2px; }
    .payment-note { font-size: 12px; color: #64748b; margin-top: 2px; }

    /* ── Financial Summary ── */
    .fin-row {
      display: flex; justify-content: space-between;
      align-items: center; padding: 7px 0;
      font-size: 14px;
    }
    .fin-row .fin-label { color: #64748b; }
    .fin-row .fin-val   { font-weight: 600; color: #1a1a1a; }
    .fin-divider { border: none; border-top: 1px solid #f1f5f9; margin: 6px 0; }
    .fin-total   { font-size: 16px; font-weight: 700; color: #1a1a1a; }
    .fin-paid    { color: #16a34a; font-weight: 600; }
    .fin-remain  { font-size: 18px; font-weight: 700; color: #D85A30; }
    .fin-remain-row {
      display: flex; justify-content: space-between;
      align-items: center; padding: 10px 0 4px;
      border-top: 2px solid #fecaca; margin-top: 4px;
    }
    .fin-remain-label { font-size: 14px; font-weight: 700; color: #D85A30; }

    /* ── Sidebar Forms ── */
    .form-label {
      font-size: 12px; font-weight: 600;
      color: #374151; margin-bottom: 5px;
    }
    .form-control, .form-select {
      border: 1px solid #dee2e6; border-radius: 7px;
      font-size: 13px; padding: 8px 11px;
      color: #1a1a1a; background: #fafafa;
    }
    .form-control:focus, .form-select:focus {
      border-color: #D85A30; background: white;
      box-shadow: 0 0 0 3px rgba(216,90,48,.1); outline: none;
    }
    .form-control::placeholder { color: #b0b8c1; }

    .btn-payment {
      background: #16a34a; color: white; border: none;
      border-radius: 7px; padding: 10px;
      font-size: 13px; font-weight: 600;
      width: 100%; cursor: pointer;
      display: flex; align-items: center;
      justify-content: center; gap: 6px;
    }
    .btn-payment:hover { background: #15803d; }

    .btn-status {
      background: #D85A30; color: white; border: none;
      border-radius: 7px; padding: 10px;
      font-size: 13px; font-weight: 600;
      width: 100%; cursor: pointer;
      display: flex; align-items: center;
      justify-content: center; gap: 6px;
    }
    .btn-status:hover { background: #b94a24; }

    @media print {
      .no-print { display: none !important; }
    }
  </style>
</head>
<body>
<% locals.currentPath = '/bookings'; %>
<%- include('../partials/sidebar') %>
<div class="main-wrapper">
  <%- include('../partials/topbar') %>
  <div class="content-area">
    <%- include('../partials/flash') %>

    <!-- Page Header -->
    <div class="page-header no-print">
      <a href="/bookings" class="btn-back">← Back</a>
      <h5 class="page-title">Booking <span style="color:#D85A30;"><%= booking.bookingId %></span></h5>
      <span class="badge-status badge-<%= booking.status %>">● <%= booking.status.toUpperCase() %></span>
      <span class="badge-status badge-<%= booking.paymentStatus %>">💳 <%= booking.paymentStatus.toUpperCase() %></span>
      <a href="/bookings/<%= booking._id %>/print" class="btn-print no-print" target="_blank">🖨️ Print Invoice</a>
      <a href="/bookings/<%= booking._id %>/edit" class="btn-edit no-print">✏️ Edit</a>
    </div>

    <div class="row g-4">
      <!-- ── Left Column ── -->
      <div class="col-12 col-lg-8">

        <!-- Booking Details -->
        <div class="section-card">
          <div class="section-header">
            📋 Booking Details
            <span class="section-header-badge">ROUTE TRIP</span>
          </div>
          <div class="section-body">
            <div class="row g-3">

              <!-- Customer -->
              <div class="col-md-6">
                <div class="info-box">
                  <div class="info-box-title">Customer</div>
                  <div class="info-box-name"><%= booking.customerName %></div>
                  <div class="info-box-line">📞 <%= booking.customerPhone %></div>
                  <% if (booking.customerCnic) { %>
                    <div class="info-box-line">🪪 CNIC: <%= booking.customerCnic %></div>
                  <% } %>
                  <% if (booking.customerAddress) { %>
                    <div class="info-box-line">📍 <%= booking.customerAddress %></div>
                  <% } %>
                </div>
              </div>

              <!-- Vehicle -->
              <div class="col-md-6">
                <div class="info-box">
                  <div class="info-box-title">Vehicle</div>
                  <% if (booking.car) { %>
                    <div class="info-box-name"><%= booking.car.name %> <%= booking.car.model %></div>
                    <span class="fleet-plate"><%= booking.car.numberPlate %></span>
                    <% if (booking.car.color) { %>
                      <div class="info-box-line" style="margin-top:6px;">🎨 <%= booking.car.color %></div>
                    <% } %>
                  <% } else { %>
                    <div class="info-box-line">—</div>
                  <% } %>
                  <% if (booking.driver) { %>
                    <div class="driver-divider">
                      <div class="driver-label">Driver</div>
                      <div class="info-box-name" style="font-size:14px;"><%= booking.driver.name %></div>
                      <div class="info-box-line">📞 <%= booking.driver.phone %></div>
                    </div>
                  <% } %>
                </div>
              </div>

              <!-- Rental Period -->
              <div class="col-md-6">
                <div class="info-box">
                  <div class="info-box-title">Travel Details</div>
                  <div class="info-box-line"><strong>Travel Date:</strong> <%= booking.travelDate ? moment(booking.travelDate).format('DD MMM YYYY') : '—' %></div>
                  <div class="info-box-line"><strong>Passengers:</strong> <%= booking.passengers || 1 %></div>
                </div>
              </div>

              <!-- Trip Route (conditional) -->
              <div class="col-md-6">
                <div class="info-box">
                  <div class="info-box-title">Route</div>
                  <% if (booking.route) { %>
                    <div class="info-box-name"><%= booking.route.origin %> → <%= booking.route.destination %></div>
                  <% } %>
                  <div class="info-box-line">📍 <strong>From:</strong> <%= booking.pickupLocation || '—' %></div>
                  <div class="info-box-line">🏁 <strong>To:</strong> <%= booking.dropoffLocation || '—' %></div>
                </div>
              </div>

            </div>

            <!-- Notes -->
            <% if (booking.notes) { %>
              <div class="notes-box">
                📝 <strong>Notes:</strong> <%= booking.notes %>
              </div>
            <% } %>
          </div>
        </div>

        <!-- Payment History -->
        <div class="section-card">
          <div class="section-header">💳 Payment History</div>
          <div class="section-body" style="padding:8px 20px 16px;">
            <% if (!booking.paymentHistory || booking.paymentHistory.length === 0) { %>
              <p class="text-muted mb-0" style="padding:12px 0;font-size:14px;">No payments recorded yet.</p>
            <% } else { %>
              <% booking.paymentHistory.forEach(function(p) { %>
              <div class="payment-item">
                <div class="payment-dot"></div>
                <div class="flex-fill">
                  <div class="payment-amount">
                    SAR <%= p.amount?.toLocaleString() %>
                    <span class="payment-method"><%= p.method %></span>
                  </div>
                  <div class="payment-meta">
                    <%= moment(p.receivedAt).format('DD MMM YYYY hh:mm A') %>
                    <% if (p.receivedBy) { %> · by <%= p.receivedBy %><% } %>
                  </div>
                  <% if (p.note) { %>
                    <div class="payment-note"><%= p.note %></div>
                  <% } %>
                </div>
              </div>
              <% }); %>
            <% } %>
          </div>
        </div>

      </div>

      <!-- ── Right Column ── -->
      <div class="col-12 col-lg-4">

        <!-- Financial Summary -->
        <div class="section-card">
          <div class="section-header">💰 Financial Summary</div>
          <div class="section-body">

            <div class="fin-row">
                <span class="fin-label">Trip Fare</span>
                <span class="fin-val">SAR <%= booking.tripFare?.toLocaleString() %></span>
              </div>

            <% if (booking.extraCharges > 0) { %>
              <div class="fin-row">
                <span class="fin-label">Extra Charges</span>
                <span class="fin-val">+ SAR <%= booking.extraCharges?.toLocaleString() %></span>
              </div>
            <% } %>

            <% if (booking.discount > 0) { %>
              <div class="fin-row">
                <span class="fin-label">Discount</span>
                <span class="fin-val" style="color:#16a34a;">− SAR <%= booking.discount?.toLocaleString() %></span>
              </div>
            <% } %>

            <hr class="fin-divider">

            <div class="fin-row">
              <span style="font-weight:700;font-size:14px;">Total Amount</span>
              <span class="fin-total">SAR <%= booking.totalAmount?.toLocaleString() %></span>
            </div>
            <div class="fin-row">
              <span class="fin-label">Paid</span>
              <span class="fin-paid">SAR <%= booking.advancePaid?.toLocaleString() %></span>
            </div>
            <div class="fin-remain-row">
              <span class="fin-remain-label">Remaining</span>
              <span class="fin-remain">SAR <%= booking.remainingAmount?.toLocaleString() %></span>
            </div>

          </div>
        </div>

        <!-- Record Payment -->
        <% if (booking.paymentStatus !== 'paid' && booking.status !== 'cancelled') { %>
        <div class="section-card no-print">
          <div class="section-header">➕ Record Payment</div>
          <div class="section-body">
            <form action="/bookings/<%= booking._id %>/payment" method="POST">
              <div class="mb-3">
                <label class="form-label">Amount (SAR) *</label>
                <input type="number" name="amount" class="form-control"
                  max="<%= booking.remainingAmount %>" placeholder="Enter amount" required min="1">
              </div>
              <div class="mb-3">
                <label class="form-label">Payment Method</label>
                <select name="method" class="form-select">
                  <option value="cash">💵 Cash</option>
                  <option value="bank">🏦 Bank Transfer</option>
                  <option value="easypaisa">📱 Easypaisa</option>
                  <option value="jazzcash">📱 JazzCash</option>
                  <option value="other">📦 Other</option>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label">Note <small style="font-weight:400;color:#94a3b8;">(optional)</small></label>
                <input type="text" name="note" class="form-control" placeholder="Optional note">
              </div>
              <button type="submit" class="btn-payment">✅ Record Payment</button>
            </form>
          </div>
        </div>
        <% } %>

        <!-- Update Status -->
        <% if (booking.status !== 'completed' && booking.status !== 'cancelled') { %>
        <div class="section-card no-print">
          <div class="section-header">🔄 Update Status</div>
          <div class="section-body">
            <form action="/bookings/<%= booking._id %>/status" method="POST">
              <div class="mb-3">
                <label class="form-label">New Status</label>
                <select name="status" class="form-select">
                  <option value="pending"   <%= booking.status==='pending'   ? 'selected' : '' %>>⏳ Pending</option>
                  <option value="confirmed" <%= booking.status==='confirmed' ? 'selected' : '' %>>✅ Confirmed</option>
                  <option value="ongoing"   <%= booking.status==='ongoing'   ? 'selected' : '' %>>🚗 Ongoing</option>
                  <option value="completed" <%= booking.status==='completed' ? 'selected' : '' %>>🏁 Completed</option>
                  <option value="cancelled">❌ Cancelled</option>
                </select>
              </div>
              <div class="mb-3" id="cancelReasonDiv" style="display:none;">
                <label class="form-label">Cancel Reason</label>
                <input type="text" name="cancelReason" class="form-control" placeholder="Reason for cancellation">
              </div>
              <button type="submit" class="btn-status">🔄 Update Status</button>
            </form>
          </div>
        </div>
        <% } %>

      </div>
    </div>

  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  document.querySelector('select[name="status"]')?.addEventListener('change', function() {
    document.getElementById('cancelReasonDiv').style.display = this.value === 'cancelled' ? '' : 'none';
  });
</script>
</body>
</html>
