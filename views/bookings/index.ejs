<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title><%= title %> — TransPort Pro</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    /* ── Header Bar (same as Routes) ── */
    .header-bar {
      background: #D85A30;
      color: white;
      padding: 0 20px;
      height: 52px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-radius: 10px 10px 0 0;
    }
    .header-bar .title { font-size: 16px; font-weight: 600; }

    /* ── Stat Cards ── */
    .stat-card {
      background: white;
      border-radius: 10px;
      border: 1px solid #dee2e6;
      padding: 14px 16px;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .stat-icon {
      width: 40px; height: 40px; border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px; flex-shrink: 0;
    }
    .stat-icon.blue   { background: #e8f0fe; }
    .stat-icon.orange { background: #fff0e8; }
    .stat-icon.green  { background: #e8f8ee; }
    .stat-icon.teal   { background: #e6f7f5; }
    .stat-icon.red    { background: #fdecea; }
    .stat-value { font-size: 22px; font-weight: 700; color: #1a1a1a; line-height: 1; }
    .stat-label { font-size: 12px; color: #6c757d; margin-top: 2px; }

    /* ── Table Card (same border pattern as Routes) ── */
    .table-card {
      border: 1px solid #dee2e6;
      border-top: none;
      border-radius: 0 0 10px 10px;
      overflow: hidden;
      background: white;
    }

    /* ── Filter Bar ── */
    .filter-bar {
      padding: 14px 20px;
      background: #f8fafc;
      border-bottom: 1px solid #e2e8f0;
    }

    /* ── Table ── */
    .table-wrap { overflow-x: auto; }
    .pro-table { width: 100%; border-collapse: collapse; }
    .pro-table thead th {
      font-size: 13px; font-weight: 500;
      color: #6c757d; background: white;
      border-bottom: 1px solid #dee2e6;
      padding: 12px 16px;
      white-space: nowrap;
    }
    .pro-table tbody td {
      padding: 13px 16px; font-size: 14px;
      vertical-align: middle;
      border-bottom: 1px solid #f1f1f1;
    }
    .pro-table tbody tr:last-child td { border-bottom: none; }
    .pro-table tbody tr:hover { background: #fafafa; }

    /* ── Badges ── */
    .badge-status {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
      text-transform: capitalize;
    }
    .badge-pending    { background: #fff3cd; color: #856404; }
    .badge-confirmed  { background: #cfe2ff; color: #084298; }
    .badge-ongoing    { background: #d1e7dd; color: #0a3622; }
    .badge-completed  { background: #d2f4ea; color: #0a3622; }
    .badge-cancelled  { background: #f8d7da; color: #842029; }
    .badge-unpaid     { background: #fdecea; color: #842029; }
    .badge-partial    { background: #fff0e8; color: #7a3000; }
    .badge-paid       { background: #d1e7dd; color: #0a3622; }

    .text-money { font-weight: 600; font-size: 13px; }
    .fleet-plate {
      background: #f1f5f9; color: #475569;
      border-radius: 4px; padding: 1px 5px;
      font-family: monospace;
    }
    .btn-xs {
      padding: 3px 10px; font-size: 12px;
      border-radius: 5px; line-height: 1.5;
    }
    .empty-state {
      text-align: center; padding: 48px 20px; color: #94a3b8;
    }
    .empty-state .empty-icon { font-size: 48px; margin-bottom: 10px; }

    .btn-new-booking {
      background: #1a1a1a; color: white; border: none;
      border-radius: 6px; padding: 0 14px; height: 34px;
      font-size: 13px; cursor: pointer;
      display: inline-flex; align-items: center; gap: 6px;
      text-decoration: none;
    }
    .btn-new-booking:hover { background: #333; color: white; }
  </style>
</head>
<body>
<% locals.currentPath = '/bookings'; %>
<%- include('../partials/sidebar') %>
<div class="main-wrapper">
  <%- include('../partials/topbar') %>
  <div class="content-area">
    <%- include('../partials/flash') %>

    <div class="row g-3 mb-4">
      <div class="col-6 col-md">
        <div class="stat-card"><div class="stat-icon blue">📋</div><div><div class="stat-value"><%= stats.total %></div><div class="stat-label">Total</div></div></div>
      </div>
      <div class="col-6 col-md">
        <div class="stat-card"><div class="stat-icon orange">⏳</div><div><div class="stat-value"><%= stats.pending %></div><div class="stat-label">Pending</div></div></div>
      </div>
      <div class="col-6 col-md">
        <div class="stat-card"><div class="stat-icon green">🚗</div><div><div class="stat-value"><%= stats.ongoing %></div><div class="stat-label">Active</div></div></div>
      </div>
      <div class="col-6 col-md">
        <div class="stat-card"><div class="stat-icon teal">✅</div><div><div class="stat-value"><%= stats.completed %></div><div class="stat-label">Completed</div></div></div>
      </div>
      <div class="col-6 col-md">
        <div class="stat-card"><div class="stat-icon red">💳</div><div><div class="stat-value"><%= stats.unpaid %></div><div class="stat-label">Unpaid</div></div></div>
      </div>
    </div>

    <div class="header-bar mb-0">
      <span class="title">📋 All Bookings</span>
      <a href="/bookings/add" class="btn-new-booking">⊕ New Booking</a>
    </div>

    <div class="table-card">

      <div class="filter-bar">
        <form method="GET" class="row g-2 align-items-end">
          <div class="col-md-3">
            <input type="text" name="search" class="form-control form-control-sm"
              placeholder="Search customer, booking ID..." value="<%= filters.search %>">
          </div>
          <div class="col-6 col-md-2">
            <select name="status" class="form-select form-select-sm">
              <option value="">All Status</option>
              <% ['pending','confirmed','ongoing','completed','cancelled'].forEach(function(s) { %>
              <option value="<%= s %>" <%= filters.status === s ? 'selected' : '' %>>
                <%= s.charAt(0).toUpperCase() + s.slice(1) %>
              </option>
              <% }); %>
            </select>
          </div>
          <div class="col-6 col-md-2">
            <select name="payment" class="form-select form-select-sm">
              <option value="">All Payments</option>
              <option value="unpaid"  <%= filters.payment === 'unpaid'  ? 'selected' : '' %>>Unpaid</option>
              <option value="partial" <%= filters.payment === 'partial' ? 'selected' : '' %>>Partial</option>
              <option value="paid"    <%= filters.payment === 'paid'    ? 'selected' : '' %>>Paid</option>
            </select>
          </div>
          <div class="col-6 col-md-2">
            <label class="form-label mb-1" style="font-size:11px;color:#64748b;">From Date</label>
            <input type="date" name="dateFrom" class="form-control form-control-sm" value="<%= filters.dateFrom || '' %>">
          </div>
          <div class="col-6 col-md-2">
            <label class="form-label mb-1" style="font-size:11px;color:#64748b;">To Date</label>
            <input type="date" name="dateTo" class="form-control form-control-sm" value="<%= filters.dateTo || '' %>">
          </div>
          <div class="col-6 col-md-1">
            <button class="btn btn-sm w-100" style="background:#D85A30;color:white;border:none;">🔍</button>
          </div>
          <div class="col-6 col-md-1">
            <a href="/bookings" class="btn btn-outline-secondary btn-sm w-100">Reset</a>
          </div>
        </form>
      </div>

      <% if (bookings.length === 0) { %>
        <div class="empty-state">
          <div class="empty-icon">📋</div>
          <p>No bookings found</p>
        </div>
      <% } else { %>
      <div class="table-wrap">
        <table class="pro-table">
          <thead>
            <tr>
              <th>Booking ID</th><th>Customer</th><th>Car</th><th>Driver</th>
              <th>Dates</th><th>Total</th><th>Paid</th>
              <th>Payment</th><th>Status</th><th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% bookings.forEach(function(b) { %>
            <tr>
              <td>
                <a href="/bookings/<%= b._id %>" class="fw-bold text-decoration-none"
                  style="color:#D85A30;"><%= b.bookingId %></a>
              </td>
              <td>
                <div class="fw-semibold"><%= b.customerName %></div>
                <div style="font-size:11px;color:#94a3b8;"><%= b.customerPhone %></div>
              </td>
              <td>
                <%= b.car ? b.car.name : '—' %>
                <% if (b.car) { %>
                  <br><span class="fleet-plate"><%= b.car.numberPlate %></span>
                <% } %>
              </td>
              <td><%= b.driver ? b.driver.name : '—' %></td>
              <td style="font-size:12px;">
                <%= b.travelDate ? moment(b.travelDate).format('DD MMM YY') : '—' %><br>
              </td>
              
              <td class="text-money">SAR <%= b.totalAmount ? b.totalAmount.toLocaleString() : '0' %></td>
              <td class="text-money text-success">SAR <%= b.advancePaid ? b.advancePaid.toLocaleString() : '0' %></td>
              <td><span class="badge-status badge-<%= b.paymentStatus %>"><%= b.paymentStatus %></span></td>
              <td><span class="badge-status badge-<%= b.status %>">● <%= b.status %></span></td>
              <td>
                <div class="d-flex gap-1">
                  <a href="/bookings/<%= b._id %>" class="btn btn-xs"
                    style="border:1px solid #D85A30;color:#D85A30;border-radius:5px;">View</a>
                  <a href="/bookings/<%= b._id %>/print" class="btn btn-xs btn-outline-secondary"
                    target="_blank">🖨</a>
                </div>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% } %>

    </div>

  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
