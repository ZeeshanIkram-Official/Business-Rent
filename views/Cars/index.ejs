<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title><%= title %> — TransPort Pro</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .header-bar {
      background: #D85A30; color: white;
      padding: 0 20px; height: 52px;
      display: flex; align-items: center;
      justify-content: space-between;
      border-radius: 10px 10px 0 0;
    }
    .header-bar .title { font-size: 16px; font-weight: 600; }

    .stat-card {
      background: white; border-radius: 10px;
      border: 1px solid #dee2e6; padding: 14px 16px;
      display: flex; align-items: center; gap: 12px;
    }
    .stat-icon {
      width: 40px; height: 40px; border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px; flex-shrink: 0;
    }
    .stat-icon.blue   { background: #e8f0fe; }
    .stat-icon.green  { background: #e8f8ee; }
    .stat-icon.orange { background: #fff0e8; }
    .stat-icon.red    { background: #fdecea; }
    .stat-value { font-size: 22px; font-weight: 700; color: #1a1a1a; line-height: 1; }
    .stat-label { font-size: 12px; color: #6c757d; margin-top: 2px; }

    .table-card {
      border: 1px solid #dee2e6; border-top: none;
      border-radius: 0 0 10px 10px; overflow: hidden; background: white;
    }

    .filter-bar {
      padding: 14px 20px; background: #f8fafc;
      border-bottom: 1px solid #e2e8f0;
    }

    .fleet-card {
      background: white; border: 1px solid #dee2e6;
      border-radius: 10px; overflow: hidden;
      transition: box-shadow .15s; height: 100%;
    }
    .fleet-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.10); }

    .fleet-img { width: 100%; height: 180px; object-fit: cover; display: block; }
    .fleet-img-placeholder {
      width: 100%; height: 180px; background: #f1f5f9;
      display: flex; align-items: center; justify-content: center;
      font-size: 52px; color: #cbd5e1;
    }
    .fleet-body { padding: 14px 16px; }
    .fleet-name { font-size: 15px; font-weight: 700; color: #1a1a1a; }
    .fleet-plate {
      background: #f1f5f9; color: #475569;
      border-radius: 4px; padding: 2px 7px;
      font-family: monospace; font-size: 12px;
    }

    .badge-status {
      display: inline-block; padding: 3px 10px;
      border-radius: 20px; font-size: 11px;
      font-weight: 600; text-transform: capitalize;
    }
    .badge-available   { background: #d1e7dd; color: #0a3622; }
    .badge-booked      { background: #cfe2ff; color: #084298; }
    .badge-maintenance { background: #f8d7da; color: #842029; }

    /* ── Booking Type Badges (NEW) ── */
    .badge-full    { background: #f0fdf4; color: #15803d; padding: 2px 8px; border-radius: 12px; font-size: 11px; font-weight: 600; }
    .badge-sharing { background: #eff6ff; color: #1d4ed8; padding: 2px 8px; border-radius: 12px; font-size: 11px; font-weight: 600; }

    .btn-add-car {
      background: #1a1a1a; color: white; border: none;
      border-radius: 6px; padding: 0 14px; height: 34px;
      font-size: 13px; cursor: pointer;
      display: inline-flex; align-items: center; gap: 6px;
      text-decoration: none;
    }
    .btn-add-car:hover { background: #333; color: white; }

    .btn-view {
      border: 1px solid #D85A30; color: #D85A30; background: white;
      border-radius: 5px; padding: 4px 12px; font-size: 12px;
      text-decoration: none; font-weight: 500; flex: 1; text-align: center;
    }
    .btn-view:hover { background: #fff0e8; color: #D85A30; }

    .btn-edit {
      border: 1px solid #dee2e6; color: #475569; background: white;
      border-radius: 5px; padding: 4px 12px; font-size: 12px;
      text-decoration: none; font-weight: 500; flex: 1; text-align: center;
    }
    .btn-edit:hover { background: #f8fafc; color: #475569; }

    .btn-delete {
      border: 1px solid #f8d7da; color: #842029; background: white;
      border-radius: 5px; padding: 4px 12px; font-size: 12px;
      font-weight: 500; cursor: pointer; flex: 1; text-align: center;
    }
    .btn-delete:hover { background: #f8d7da; color: #842029; }

    .modal-confirm .modal-header { background: #D85A30; color: white; border-radius: 10px 10px 0 0; }
    .modal-confirm .modal-content { border-radius: 10px; border: none; }

    .empty-state { text-align: center; padding: 48px 20px; color: #94a3b8; }
    .empty-icon  { font-size: 48px; margin-bottom: 10px; }
    .cars-grid   { padding: 16px; }
  </style>
</head>
<body>
<% locals.currentPath = '/cars'; %>
<%- include('../partials/sidebar') %>
<div class="main-wrapper">
  <%- include('../partials/topbar') %>
  <div class="content-area">
    <%- include('../partials/flash') %>

    <!-- Stats -->
    <div class="row g-3 mb-4">
      <div class="col-6 col-md-3">
        <div class="stat-card"><div class="stat-icon blue">🚘</div><div><div class="stat-value"><%= stats.total %></div><div class="stat-label">Total Cars</div></div></div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-card"><div class="stat-icon green">✅</div><div><div class="stat-value"><%= stats.available %></div><div class="stat-label">Available</div></div></div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-card"><div class="stat-icon orange">📋</div><div><div class="stat-value"><%= stats.booked %></div><div class="stat-label">On Rent</div></div></div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-card"><div class="stat-icon red">🔧</div><div><div class="stat-value"><%= stats.maintenance %></div><div class="stat-label">Maintenance</div></div></div>
      </div>
    </div>

    <!-- Header Bar -->
    <div class="header-bar mb-0">
      <span class="title">🚘 Car Fleet</span>
      <% if (currentRole === 'admin') { %>
        <a href="/cars/add" class="btn-add-car">⊕ Add Car</a>
      <% } %>
    </div>

    <!-- Table Card -->
    <div class="table-card">

      <!-- Filter Bar -->
      <div class="filter-bar">
        <form method="GET" class="row g-2 align-items-end">
          <div class="col-md-4">
            <input type="text" name="search" class="form-control form-control-sm"
              placeholder="Search by name, plate, model..." value="<%= search %>">
          </div>
          <div class="col-md-2">
            <select name="status" class="form-select form-select-sm">
              <option value="">All Status</option>
              <option value="available"   <%= status === 'available'   ? 'selected' : '' %>>✅ Available</option>
              <option value="booked"      <%= status === 'booked'      ? 'selected' : '' %>>📋 On Rent</option>
              <option value="maintenance" <%= status === 'maintenance' ? 'selected' : '' %>>🔧 Maintenance</option>
            </select>
          </div>
          <!-- ── Booking Type Filter (NEW) ── -->
          <div class="col-md-2">
            <select name="bookingType" class="form-select form-select-sm">
              <option value="">All Types</option>
              <option value="full"    <%= bookingType === 'full'    ? 'selected' : '' %>>🚗 Full Vehicle</option>
              <option value="sharing" <%= bookingType === 'sharing' ? 'selected' : '' %>>💺 Sharing</option>
            </select>
          </div>
          <div class="col-md-2">
            <button class="btn btn-sm w-100" style="background:#D85A30;color:white;border:none;">🔍 Search</button>
          </div>
          <div class="col-md-2">
            <a href="/cars" class="btn btn-outline-secondary btn-sm w-100">Reset</a>
          </div>
        </form>
      </div>

      <!-- Cars Grid -->
      <% if (cars.length === 0) { %>
        <div class="empty-state">
          <div class="empty-icon">🚘</div>
          <p>No cars found</p>
        </div>
      <% } else { %>
      <div class="row g-3 cars-grid">
        <% cars.forEach(function(car) { %>
        <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
          <div class="fleet-card">
            <% if (car.carImage) { %>
              <img src="<%= car.carImage %>" class="fleet-img" alt="<%= car.name %>">
            <% } else { %>
              <div class="fleet-img-placeholder">🚗</div>
            <% } %>
            <div class="fleet-body">
              <div class="d-flex justify-content-between align-items-start mb-2">
                <div class="fleet-name"><%= car.name %></div>
                <span class="badge-status badge-<%= car.status %>"><%= car.status %></span>
              </div>
              <!-- ── Plate + Booking Type Badge (NEW) ── -->
              <div class="mb-2 d-flex align-items-center gap-1 flex-wrap">
                <span class="fleet-plate"><%= car.numberPlate %></span>
                <% if (car.bookingType === 'sharing') { %>
                  <span class="badge-sharing">💺 Sharing</span>
                <% } else { %>
                  <span class="badge-full">🚗 Full</span>
                <% } %>
              </div>
              <div style="font-size:12px;color:#64748b;" class="mb-1">
                📅 <%= car.model %> <%= car.year || '' %> &nbsp;|&nbsp; ⛽ <%= car.fuelType %>
              </div>
              <% if (car.ratePerDay > 0) { %>
              <div style="font-size:13px;font-weight:700;color:#059669;" class="mb-3">
                SAR <%= car.ratePerDay.toLocaleString() %>/day
              </div>
              <% } %>
              <div class="d-flex gap-2 mt-2">
                <a href="/cars/<%= car._id %>" class="btn-view">View</a>
                <% if (currentRole === 'admin') { %>
                  <a href="/cars/<%= car._id %>/edit" class="btn-edit">Edit</a>
                  <button class="btn-delete" onclick="confirmDelete('<%= car._id %>', '<%= car.name %>')">🗑 Delete</button>
                <% } %>
              </div>
            </div>
          </div>
        </div>
        <% }); %>
      </div>
      <% } %>

    </div><!-- /table-card -->

  </div>
</div>

<!-- Delete Confirm Modal -->
<div class="modal fade modal-confirm" id="deleteModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h6 class="modal-title fw-bold">🗑 Confirm Delete</h6>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" style="font-size:14px;">
        <p class="mb-1">Kya aap <strong id="carNameText"></strong> ko permanently delete karna chahte hain?</p>
        <p class="text-danger mb-0" style="font-size:12px;">⚠️ Yeh action undo nahi ho sakta — record hamesha ke liye delete ho jayega.</p>
      </div>
      <div class="modal-footer border-0">
        <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <form id="deleteForm" method="POST" style="display:inline;">
          <input type="hidden" name="_method" value="DELETE">
          <button type="submit" class="btn btn-sm btn-danger">🗑 Delete</button>
        </form>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function confirmDelete(id, name) {
    document.getElementById('carNameText').textContent = name;
    document.getElementById('deleteForm').action = '/cars/' + id + '?_method=DELETE';
    new bootstrap.Modal(document.getElementById('deleteModal')).show();
  }
</script>
</body>
</html>